  </div>
</div>

<!-- MODAL -->
<div class="fifty-modal-overlay" id="fiftyModal" onclick="fiftyCloseModalOutside(event)">
  <div class="fifty-modal" id="fiftyModalInner">
    <button class="fifty-modal-close" onclick="fiftyCloseModal()">✕</button>
    <h3>Let's get started</h3>
