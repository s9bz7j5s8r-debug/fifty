  </div>
</div>

<!-- CART OVERLAY -->
<div class="fifty-cart-overlay" id="fiftyCartOverlay" onclick="fiftyCloseCart()"></div>

<!-- CART DRAWER -->
<div class="fifty-cart-drawer" id="fiftyCartDrawer" role="dialog" aria-modal="true" aria-label="Shopping cart">

  <div class="fifty-cart-head">
    <div class="fifty-cart-head-left">
      <span class="fifty-cart-title">Your Cart</span>
      <span class="fifty-cart-count-pill" id="fiftyCartCountPill">{{ cart.item_count }}</span>
    </div>
    <button class="fifty-cart-close" onclick="fiftyCloseCart()" aria-label="Close cart">✕</button>
  </div>

  <div class="fifty-cart-items" id="fiftyCartItems">
    {% if cart.item_count > 0 %}
      {% comment %} Collect bundle item keys + total {% endcomment %}
      {% assign sub_key = '' %}
      {% assign setup_key = '' %}
      {% assign bundle_total = 0 %}
      {% for item in cart.items %}
        {% if item.variant_id == 53809850089811 %}
          {% assign sub_key = item.key %}
          {% assign bundle_total = bundle_total | plus: item.line_price %}
        {% elsif item.variant_id == 53809949933907 %}
          {% assign setup_key = item.key %}
          {% assign bundle_total = bundle_total | plus: item.line_price %}
        {% endif %}
      {% endfor %}

      {% comment %} Render bundle block if subscription or setup fee present {% endcomment %}
      {% if sub_key != '' or setup_key != '' %}
        <div class="fifty-cart-bundle">
          <div class="fifty-cart-bundle-top">
            <span class="fifty-cart-bundle-badge">Bundle</span>
            <span class="fifty-cart-bundle-name">The Fifty Plan</span>
          </div>
          <div class="fifty-cart-bundle-lines">
            {% for item in cart.items %}
              {% if item.variant_id == 53809850089811 or item.variant_id == 53809949933907 %}
                <div class="fifty-cart-bundle-line">
                  <span class="fifty-cart-bundle-line-name">{{ item.product.title }}</span>
                  <span class="fifty-cart-bundle-line-price">{{ item.line_price | money }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="fifty-cart-bundle-foot">
            <span class="fifty-cart-bundle-total-label">Bundle total</span>
            <div class="fifty-cart-bundle-total-right">
              <span class="fifty-cart-bundle-total">{{ bundle_total | money }}</span>
              <button class="fifty-cart-item-remove" onclick="fiftyRemoveBundleKeys('{{ sub_key }}','{{ setup_key }}')" title="Remove plan" aria-label="Remove plan">✕</button>
            </div>
          </div>
        </div>
      {% endif %}

      {% comment %} Render non-bundle items (logo add-on etc) normally {% endcomment %}
      {% for item in cart.items %}
        {% unless item.variant_id == 53809850089811 or item.variant_id == 53809949933907 %}
          <div class="fifty-cart-item" data-key="{{ item.key }}">
            <div class="fifty-cart-item-img">
              {% if item.image %}
                <img src="{{ item.image | img_url: '120x120', crop: 'center' }}" alt="{{ item.title | escape }}" loading="lazy">
              {% else %}
                <span class="fifty-cart-item-placeholder">F.</span>
              {% endif %}
            </div>
            <div class="fifty-cart-item-body">
              <div class="fifty-cart-item-title">{{ item.product.title }}</div>
              {% unless item.variant.title == 'Default Title' %}
                <div class="fifty-cart-item-variant">{{ item.variant.title }}</div>
              {% endunless %}
              <div class="fifty-cart-item-row">
                <div class="fifty-cart-qty">
                  <button class="fifty-cart-qty-btn" onclick="fiftyUpdateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})" aria-label="Decrease">−</button>
                  <span class="fifty-cart-qty-num">{{ item.quantity }}</span>
                  <button class="fifty-cart-qty-btn" onclick="fiftyUpdateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})" aria-label="Increase">+</button>
                </div>
                <div class="fifty-cart-item-right">
                  <span class="fifty-cart-item-price">{{ item.line_price | money }}</span>
                  <button class="fifty-cart-item-remove" onclick="fiftyUpdateQty('{{ item.key }}', 0)" title="Remove" aria-label="Remove {{ item.title | escape }}">✕</button>
                </div>
              </div>
            </div>
          </div>
        {% endunless %}
      {% endfor %}
    {% else %}
      <div class="fifty-cart-empty">
        <div class="fifty-cart-empty-bag">
          <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </div>
        <div class="fifty-cart-empty-title">Your cart is empty.</div>
        <div class="fifty-cart-empty-sub">No items added yet. Start by picking your plan.</div>
        <a href="/products/fifty-website-subscription" class="fifty-cart-empty-cta" onclick="fiftyCloseCart()">Get Started →</a>
      </div>
    {% endif %}
  </div>

  {% if cart.item_count > 0 %}
  <div class="fifty-cart-foot" id="fiftyCartFoot">
    <div class="fifty-cart-subtotal-row">
      <span class="fifty-cart-subtotal-label">Due Today</span>
      <span class="fifty-cart-subtotal-amount" id="fiftyCartTotal">{{ cart.total_price | money }}</span>
    </div>
    <p class="fifty-cart-foot-note">Includes first month + setup fee. Subscription renews at £50/month. Cancel any time.</p>
    <a href="/checkout" class="fifty-cart-checkout">Proceed to Checkout &nbsp;→</a>
    <button class="fifty-cart-continue" onclick="fiftyCloseCart()">← Continue Shopping</button>
  </div>
  {% else %}
  <div class="fifty-cart-foot" id="fiftyCartFoot" style="display:none"></div>
  {% endif %}

</div>

<script>
  function fiftyToggleNav() {
    var btn = document.getElementById('fiftyHamburger');
    var menu = document.getElementById('fiftyMobileNav');
    btn.classList.toggle('open');
    menu.classList.toggle('open');
  }

  function fiftyOpenTC() { document.getElementById('fiftyTCOverlay').classList.add('active'); }
  function fiftyCloseTC() { document.getElementById('fiftyTCOverlay').classList.remove('active'); }
  function fiftyCloseTCOutside(e) { if (e.target === document.getElementById('fiftyTCOverlay')) fiftyCloseTC(); }

  function fiftyOpenPricing() { document.getElementById('fiftyPricingOverlay').classList.add('active'); }
  function fiftyClosePricing() { document.getElementById('fiftyPricingOverlay').classList.remove('active'); }
  function fiftyClosePricingOutside(e) { if (e.target === document.getElementById('fiftyPricingOverlay')) fiftyClosePricing(); }

  function fiftyOpenIncluded() { document.getElementById('fiftyIncludedOverlay').classList.add('active'); }
  function fiftyCloseIncluded() { document.getElementById('fiftyIncludedOverlay').classList.remove('active'); }
  function fiftyCloseIncludedOutside(e) { if (e.target === document.getElementById('fiftyIncludedOverlay')) fiftyCloseIncluded(); }

  function fiftyOpenModal() { document.getElementById('fiftyModal').classList.add('active'); }
  function fiftyCloseModal() { document.getElementById('fiftyModal').classList.remove('active'); }
  function fiftyCloseModalOutside(e) { if (e.target === document.getElementById('fiftyModal')) fiftyCloseModal(); }
  function fiftySubmitForm() {
    document.getElementById('fiftyModalInner').innerHTML = '<div style="text-align:center;padding:2rem 0"><div style="font-size:3rem;margin-bottom:1rem">✓</div><h3 style="font-family:\'Playfair Display\',serif;font-size:1.8rem;margin-bottom:0.5rem;color:var(--ink)">Enquiry sent!</h3><p style="color:var(--muted);font-size:0.85rem;margin-bottom:1.5rem">We\'ll be in touch within 24 hours.</p><button onclick="fiftyCloseModal()" style="background:var(--ink);color:var(--paper);border:none;padding:0.75rem 2rem;font-family:\'DM Mono\',monospace;font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;border-radius:2px;cursor:pointer">Close</button></div>';
  }
  function fiftyToggleFaq(btn) {
    const item = btn.closest('.fifty-faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.fifty-faq-item').forEach(i => i.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }
  const fiftyObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) { setTimeout(() => entry.target.classList.add('visible'), i * 80); fiftyObserver.unobserve(entry.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fifty-reveal').forEach(el => fiftyObserver.observe(el));

  const fiftyCards = document.querySelectorAll('.fifty-portfolio-card');
  const fiftyPortfolioData = [
    { name: 'The Anchor', tag: 'Restaurant · Edinburgh' },
    { name: 'Bloom', tag: 'Hair & Beauty · Glasgow' },
    { name: 'Swift Plumbing', tag: 'Trades · Fife' },
    { name: 'Iron & Willow', tag: 'Fitness · Dundee' },
    { name: 'The Morning Press', tag: 'Café · Stirling' },
    { name: 'Clarity Accountants', tag: 'Professional Services · Aberdeen' }
  ];
  let fiftyCurrentLightbox = 0;
  function fiftyOpenLightbox(i) {
    fiftyCurrentLightbox = i;
    const svg = fiftyCards[i].querySelector('svg').cloneNode(true);
    const mount = document.getElementById('fiftyLightboxMockup');
    mount.innerHTML = ''; mount.appendChild(svg);
    document.getElementById('fiftyLightboxInfo').innerHTML = '<strong>' + fiftyPortfolioData[i].name + '</strong> ' + fiftyPortfolioData[i].tag;
    document.getElementById('fiftyLightbox').classList.add('active');
  }
  function fiftyCloseLightbox() { document.getElementById('fiftyLightbox').classList.remove('active'); }
  function fiftyNavLightbox(dir) { fiftyCurrentLightbox = (fiftyCurrentLightbox + dir + fiftyCards.length) % fiftyCards.length; fiftyOpenLightbox(fiftyCurrentLightbox); }
  document.getElementById('fiftyLightbox').addEventListener('click', (e) => { if (e.target.id === 'fiftyLightbox') fiftyCloseLightbox(); });

  // ═══════════════════════════════════════════════
  // (brand animation is pure CSS — no JS needed)
  (function() {
    var cv = document.getElementById('fiftyCinemaCanvas');
    if (!cv) return;
    var cx = cv.getContext('2d');

    // HiDPI / Retina — render at device pixel ratio, capped at 2.5x
    var DPR = Math.min(window.devicePixelRatio || 1, 2.5);
    var W = 1920, H = 804;  // logical drawing space (all coords in these units)
    cv.width  = Math.round(W * DPR);
    cv.height = Math.round(H * DPR);
    cx.scale(DPR, DPR);
    cx.imageSmoothingEnabled  = true;
    cx.imageSmoothingQuality  = 'high';

    var t = 0, dt = 0, lastTs = null, playing = false, started = false;
    var LOOP = 64; // loop duration seconds

    // ── Camera ──────────────────────────────────
    var cam = { x:0, y:0, z:-1200, rx:0, ry:0, fl:900, shake:0 };
    var mouseX = null, mouseY = null;

    // ── Grain (pre-baked at logical resolution) ──
    var grains = [], GN = 8, grainIdx = 0;
    for (var _g = 0; _g < GN; _g++) {
      var _gc = document.createElement('canvas'); _gc.width=W; _gc.height=H;
      var _gx = _gc.getContext('2d'), _id = _gx.createImageData(W,H), _d = _id.data;
      for (var _j=0; _j<_d.length; _j+=4) {
        var _v=(Math.random()*62)|0;
        _d[_j]=_d[_j+1]=_d[_j+2]=_v; _d[_j+3]=20;
      }
      _gx.putImageData(_id,0,0); grains.push(_gc);
    }

    // ── Pre-cached vignette + letterbox ──────────
    var vigCv = document.createElement('canvas'); vigCv.width=W; vigCv.height=H;
    var vigCx = vigCv.getContext('2d');
    (function(){
      var vg=vigCx.createRadialGradient(W/2,H/2,H*.12,W/2,H/2,H*.9);
      vg.addColorStop(0,'rgba(0,0,0,0)'); vg.addColorStop(1,'rgba(0,0,0,.82)');
      vigCx.fillStyle=vg; vigCx.fillRect(0,0,W,H);
      vigCx.fillStyle='#000'; vigCx.fillRect(0,0,W,56); vigCx.fillRect(0,H-56,W,56);
    })();

    // ── Glow sprites (pre-rendered radial halos) ─
    // Used instead of per-particle shadowBlur — far faster, higher quality
    var PCOLS = [[0,190,255],[200,64,26],[255,255,255],[255,180,40],[120,80,220]];
    var glowSprites = PCOLS.map(function(c){
      var s=document.createElement('canvas'); s.width=s.height=128;
      var sx=s.getContext('2d');
      var g=sx.createRadialGradient(64,64,0,64,64,64);
      g.addColorStop(0,'rgba('+c[0]+','+c[1]+','+c[2]+',1)');
      g.addColorStop(.25,'rgba('+c[0]+','+c[1]+','+c[2]+',.55)');
      g.addColorStop(.6,'rgba('+c[0]+','+c[1]+','+c[2]+',.15)');
      g.addColorStop(1,'rgba(0,0,0,0)');
      sx.fillStyle=g; sx.fillRect(0,0,128,128); return s;
    });

    // ── Bloom canvas (quarter-size — upscaling = blur = bloom) ──
    var blmW=Math.round(W/4), blmH=Math.round(H/4);
    var blmCv=document.createElement('canvas'); blmCv.width=blmW; blmCv.height=blmH;
    var blmCx=blmCv.getContext('2d'); blmCx.imageSmoothingEnabled=true;

    // ── 3D Math ──────────────────────────────────
    var PHI = (1+Math.sqrt(5))/2;
    var ICO_V = [[-1,PHI,0],[1,PHI,0],[-1,-PHI,0],[1,-PHI,0],[0,-1,PHI],[0,1,PHI],[0,-1,-PHI],[0,1,-PHI],[PHI,0,-1],[PHI,0,1],[-PHI,0,-1],[-PHI,0,1]];
    ICO_V = ICO_V.map(function(v){var l=Math.sqrt(v[0]*v[0]+v[1]*v[1]+v[2]*v[2]);return[v[0]/l,v[1]/l,v[2]/l];});
    var ICO_E = [[0,1],[0,5],[0,7],[0,10],[0,11],[1,5],[1,7],[1,8],[1,9],[2,3],[2,4],[2,6],[2,10],[2,11],[3,4],[3,6],[3,8],[3,9],[4,5],[4,9],[4,11],[5,9],[6,7],[6,8],[6,10],[7,8],[7,10],[8,9],[10,11],[1,9]];

    function rot3(v,rx,ry,rz){
      var x=v[0],y=v[1],z=v[2],c,s,t2;
      c=Math.cos(rz);s=Math.sin(rz);t2=x*c-y*s;y=x*s+y*c;x=t2;
      c=Math.cos(rx);s=Math.sin(rx);t2=y*c-z*s;z=y*s+z*c;y=t2;
      c=Math.cos(ry);s=Math.sin(ry);t2=x*c+z*s;z=-x*s+z*c;x=t2;
      return[x,y,z];
    }

    function proj(wx,wy,wz){
      var dx=wx-cam.x, dy=wy-cam.y, dz=wz-cam.z;
      var r,c,s;
      c=Math.cos(cam.ry);s=Math.sin(cam.ry);r=dx*c-dz*s;dz=dx*s+dz*c;dx=r;
      c=Math.cos(cam.rx);s=Math.sin(cam.rx);r=dy*c-dz*s;dz=dy*s+dz*c;dy=r;
      if(dz<=10)return null;
      var sc=cam.fl/dz;
      return{x:W/2+dx*sc+(Math.random()-.5)*cam.shake,y:H/2+dy*sc+(Math.random()-.5)*cam.shake,sc:sc,dz:dz};
    }

    // ── Particles ────────────────────────────────
    var PC = 5200, particles = [];
    for(var _p=0;_p<PC;_p++){
      particles.push({
        x:(Math.random()-.5)*5000, y:(Math.random()-.5)*4000, z:Math.random()*5000-2000,
        vx:0,vy:0,vz:0,
        bvz:Math.random()*.6+.15,
        sz:Math.random()*2.8+.4,
        ci:Math.floor(Math.random()*PCOLS.length),
        al:Math.random()*.7+.25
      });
    }

    // ── Geo objects ──────────────────────────────
    var geos = [];
    for(var _i=0;_i<10;_i++){
      geos.push({
        x:(Math.random()-.5)*2200, y:(Math.random()-.5)*900, z:Math.random()*4000+600,
        rx:Math.random()*6.28, ry:Math.random()*6.28, rz:Math.random()*6.28,
        srx:(Math.random()-.5)*.9, sry:(Math.random()-.5)*.9, srz:(Math.random()-.5)*.3,
        sz:Math.random()*90+35,
        col:Math.random()<.5?[0,190,255]:[200,64,26],
        al:.65
      });
    }
    // Rings
    for(var _r=0;_r<5;_r++){
      geos.push({
        type:'ring',
        x:(Math.random()-.5)*1800,y:(Math.random()-.5)*700,z:Math.random()*3000+700,
        rx:Math.random()*3.14,ry:0,rz:Math.random()*6.28,
        srx:(Math.random()-.5)*.5,sry:(Math.random()-.5)*.4,srz:0,
        sz:Math.random()*130+70,
        col:[255,255,255],al:.28
      });
    }

    // ── Energy rings ─────────────────────────────
    var rings = [];
    function spawnRing(x,y,z,col){ rings.push({x:x||0,y:y||0,z:z||0,r:0,maxR:1400,spd:900+Math.random()*500,col:col||[255,255,255],al:.9}); }

    // ── Debris ───────────────────────────────────
    var debris=[], boomDone=false;
    function triggerBoom(){
      for(var _b=0;_b<240;_b++){
        var ang=Math.random()*6.28,spd=Math.random()*700+120;
        debris.push({x:0,y:0,z:500,vx:Math.cos(ang)*spd,vy:(Math.random()-.5)*700,vz:Math.random()*500-200,sz:Math.random()*7+2,al:1,life:1,dec:Math.random()*.35+.08,col:Math.random()<.5?[0,190,255]:[200,64,26]});
      }
      cam.shake=18;
      spawnRing(0,0,500,[255,210,80]);
      spawnRing(0,0,500,[0,190,255]);
      spawnRing(0,0,500,[200,64,26]);
    }

    // ── Text flashes ─────────────────────────────
    var FLASHES=[
      {txt:'BUILD FASTER',    st:10.5, dur:1.6, sz:130},
      {txt:'MOVE DIFFERENT',  st:13.2, dur:1.6, sz:118},
      {txt:'CREATE MOMENTUM', st:16.0, dur:1.6, sz:108},
      {txt:'DOMINATE ATTENTION',st:18.8,dur:1.6, sz:98},
      {txt:'THE FUTURE STARTS HERE',st:21.8,dur:2.2,sz:90}
    ];

    // ═══ DRAW FUNCTIONS ══════════════════════════

    function clamp(v,a,b){return Math.max(a,Math.min(b,v));}
    function easeOut(x){return 1-Math.pow(1-x,3);}
    function fadeVal(s,fi,ho,fo,time){
      if(time<s)return 0; var r=time-s;
      if(r<fi)return easeOut(r/fi);
      if(r<fi+ho)return 1;
      if(r<fi+ho+fo)return 1-(r-fi-ho)/fo;
      return 0;
    }

    function drawBg(){
      // Motion blur: semi-transparent fill each frame
      var blurA = t>=7&&t<13 ? .06 : t>=40 ? .28 : .14;
      cx.save(); cx.globalAlpha=blurA; cx.fillStyle='#000'; cx.fillRect(0,0,W,H); cx.restore();

      // Nebula color wash
      var nI = t<3 ? t/3 : t<7 ? 1+(t-3)/4*1.5 : t<10 ? 2.5-(t-7)/3*2 : t<22 ? .5+Math.sin(t*1.8)*.4 : t<35 ? 1 : t<45 ? 1-(t-35)/10*.6 : .4;
      if(nI>.02){
        var phase=t*.08, nx=W/2+Math.sin(phase)*180, ny=H/2+Math.cos(phase*.7)*90;
        var nb=cx.createRadialGradient(nx,ny,0,nx,ny,H*.85);
        nb.addColorStop(0,'rgba(200,64,26,'+(0.055*nI)+')');
        nb.addColorStop(.45,'rgba(0,120,200,'+(0.035*nI)+')');
        nb.addColorStop(1,'rgba(0,0,0,0)');
        cx.fillStyle=nb; cx.fillRect(0,0,W,H);
      }
    }

    function drawRings(){
      rings=rings.filter(function(rg){
        rg.r+=rg.spd*dt; rg.al=1-rg.r/rg.maxR;
        var p=proj(rg.x,rg.y,rg.z); if(!p)return rg.r<rg.maxR;
        var sr=rg.r*p.sc;
        cx.save(); cx.globalAlpha=rg.al*.85;
        cx.strokeStyle='rgb('+rg.col.join(',')+')'; cx.lineWidth=Math.max(1,3*p.sc);
        cx.shadowColor='rgb('+rg.col.join(',')+')'; cx.shadowBlur=25;
        cx.beginPath(); cx.arc(p.x,p.y,Math.max(1,sr),0,Math.PI*2); cx.stroke();
        cx.restore(); return rg.r<rg.maxR;
      });
    }

    function drawParticles(){
      // Bucket by colour — one fillStyle set per colour group = far fewer state changes
      // Large particles get a pre-rendered glow sprite instead of shadowBlur
      var buckets=[[],[],[],[],[]];
      for(var _pi=0;_pi<particles.length;_pi++){
        var p=particles[_pi];
        var pp=proj(p.x,p.y,p.z); if(!pp)continue;
        if(pp.x<-80||pp.x>W+80||pp.y<-80||pp.y>H+80)continue;
        var sz2=Math.max(.3,p.sz*pp.sc*2.4);
        var al2=p.al*clamp(pp.sc*1.9,0,1);
        if(al2<.008)continue;
        buckets[p.ci].push({x:pp.x,y:pp.y,sz:sz2,al:al2});
      }
      cx.save();
      for(var ci=0;ci<PCOLS.length;ci++){
        var bk=buckets[ci]; if(!bk.length)continue;
        var c=PCOLS[ci];
        var col='rgb('+c[0]+','+c[1]+','+c[2]+')';
        // Tiny particles — batch into a single path per colour
        cx.fillStyle=col; cx.beginPath();
        for(var bi=0;bi<bk.length;bi++){
          var bp=bk[bi]; if(bp.sz>=2)continue;
          cx.globalAlpha=bp.al;
          cx.moveTo(bp.x+bp.sz,bp.y);
          cx.arc(bp.x,bp.y,bp.sz,0,6.283);
        }
        cx.fill();
        // Medium + large — glow sprite (radial halo, no shadowBlur)
        for(var bi2=0;bi2<bk.length;bi2++){
          var bp2=bk[bi2]; if(bp2.sz<2)continue;
          var halo=bp2.sz*7;
          cx.globalAlpha=bp2.al*.75;
          cx.drawImage(glowSprites[ci],bp2.x-halo/2,bp2.y-halo/2,halo,halo);
          // Sharp bright core on top
          cx.globalAlpha=bp2.al;
          cx.fillStyle=col;
          cx.beginPath(); cx.arc(bp2.x,bp2.y,bp2.sz*.55,0,6.283); cx.fill();
        }
      }
      cx.globalAlpha=1; cx.restore();
    }

    function drawGeos(){
      var gA=0;
      if(t<3)gA=t/3*.75; else if(t<30)gA=.75; else if(t<38)gA=.75-(t-30)/8*.75;
      if(gA<.01)return;

      geos.forEach(function(obj){
        if(obj.type==='ring'){
          var segs=64,pts=[];
          for(var _s=0;_s<=segs;_s++){
            var ang=_s/segs*6.28;
            var rv=rot3([Math.cos(ang)*obj.sz,0,Math.sin(ang)*obj.sz],obj.rx,obj.ry,obj.rz);
            pts.push(proj(obj.x+rv[0],obj.y+rv[1],obj.z+rv[2]));
          }
          cx.save(); cx.globalAlpha=gA*obj.al;
          cx.strokeStyle='rgb('+obj.col.join(',')+')'; cx.lineWidth=1.2;
          cx.shadowColor='rgb('+obj.col.join(',')+')'; cx.shadowBlur=5;
          cx.beginPath(); var mv=true;
          pts.forEach(function(pt){if(!pt){mv=true;return;}if(mv){cx.moveTo(pt.x,pt.y);mv=false;}else cx.lineTo(pt.x,pt.y);});
          cx.stroke(); cx.restore();
        } else {
          var vs=ICO_V.map(function(v){
            var rv=rot3([v[0]*obj.sz,v[1]*obj.sz,v[2]*obj.sz],obj.rx,obj.ry,obj.rz);
            return proj(obj.x+rv[0],obj.y+rv[1],obj.z+rv[2]);
          });
          var spMult=t>=7&&t<22?1+(t-7)*.45:t>=22&&t<35?Math.max(1,9-(t-22)*.55):1;
          obj.rx+=obj.srx*dt*spMult; obj.ry+=obj.sry*dt*spMult; obj.rz+=obj.srz*dt*spMult;
          cx.save(); cx.globalAlpha=gA*obj.al;
          cx.strokeStyle='rgb('+obj.col.join(',')+')'; cx.lineWidth=1.6;
          cx.shadowColor='rgb('+obj.col.join(',')+')'; cx.shadowBlur=9;
          ICO_E.forEach(function(e){
            var a=vs[e[0]],b=vs[e[1]]; if(!a||!b)return;
            if(Math.abs(a.x-b.x)>W*.6||Math.abs(a.y-b.y)>H*.6)return;
            cx.beginPath(); cx.moveTo(a.x,a.y); cx.lineTo(b.x,b.y); cx.stroke();
          });
          cx.restore();
        }
      });
    }

    function drawDebris(){
      debris=debris.filter(function(db){
        db.x+=db.vx*dt; db.y+=db.vy*dt; db.z+=db.vz*dt;
        db.vy+=60*dt; db.life-=db.dec*dt;
        if(db.life<=0)return false;
        var p=proj(db.x,db.y,db.z); if(!p)return db.life>0;
        var sz2=Math.max(.5,db.sz*p.sc);
        cx.save(); cx.globalAlpha=db.life;
        cx.fillStyle='rgb('+db.col.join(',')+')';
        cx.shadowColor='rgb('+db.col.join(',')+')'; cx.shadowBlur=sz2*4;
        cx.fillRect(p.x-sz2/2,p.y-sz2/2,sz2,sz2);
        cx.restore(); return db.life>0;
      });
    }

    function drawFlashes(){
      FLASHES.forEach(function(f){
        if(t<f.st||t>f.st+f.dur)return;
        var prog=(t-f.st)/f.dur;
        var al=prog<.12?prog/.12:prog>.72?1-(prog-.72)/.28:1;
        // Chromatic aberration offset
        var off=Math.sin(t*30)*3*(1-prog);
        cx.save();
        cx.font='900 '+f.sz+'px "Bebas Neue","Arial Black",sans-serif';
        cx.textAlign='center'; cx.textBaseline='middle';
        // Red channel
        cx.globalAlpha=al*.7; cx.fillStyle='rgba(255,0,50,.8)';
        cx.shadowBlur=0; cx.fillText(f.txt,W/2+off,H/2+off*.5);
        // Blue channel
        cx.globalAlpha=al*.7; cx.fillStyle='rgba(0,190,255,.8)';
        cx.fillText(f.txt,W/2-off,H/2-off*.5);
        // White main
        cx.globalAlpha=al; cx.fillStyle='#fff';
        cx.shadowColor='rgba(0,190,255,.9)'; cx.shadowBlur=50;
        cx.fillText(f.txt,W/2,H/2);
        // Second glow
        cx.globalAlpha=al*.35; cx.shadowBlur=100;
        cx.fillText(f.txt,W/2,H/2);
        cx.restore();
      });
    }

    function drawLogo(){
      var lA=0, lSz=200, lY=H/2;
      if(t<5){ lA=clamp(t/2,0,1)*.55; }
      else if(t<8){ lA=.55*(1-(t-5)/3); }
      else if(t>=45){
        var lp=easeOut(clamp((t-45)/3,0,1));
        lA=lp; lSz=200+lp*60; lY=H/2-65;
        lA*=.82+Math.sin(t*2.8)*.18;
      }
      if(lA<.01)return;

      cx.save();
      // Glow halo
      cx.globalAlpha=lA*.5;
      var halo=cx.createRadialGradient(W/2,lY,0,W/2,lY,H*.55);
      halo.addColorStop(0,'rgba(200,64,26,.22)'); halo.addColorStop(.4,'rgba(0,120,200,.08)'); halo.addColorStop(1,'rgba(0,0,0,0)');
      cx.fillStyle=halo; cx.fillRect(0,0,W,H);

      cx.globalAlpha=lA;
      cx.fillStyle='#fff';
      cx.font='900 '+Math.round(lSz)+'px "Playfair Display",Georgia,serif';
      cx.textAlign='center'; cx.textBaseline='middle';
      cx.shadowColor='rgba(200,64,26,.9)'; cx.shadowBlur=70;
      cx.fillText('Fifty.',W/2,lY);
      cx.globalAlpha=lA*.35; cx.shadowBlur=140;
      cx.fillText('Fifty.',W/2,lY);

      if(t>=48){
        var tA=clamp((t-48)/2,0,1);
        cx.globalAlpha=lA*tA; cx.shadowBlur=0;
        cx.fillStyle='rgba(255,255,255,.42)';
        cx.font='300 24px "DM Mono",monospace';
        cx.fillText('£50 A MONTH  ·  PROFESSIONALLY DESIGNED  ·  FULLY HOSTED  ·  CANCEL ANYTIME',W/2,lY+108);
      }
      cx.restore();
    }

    function drawFlare(){
      if(t<7||t>13)return;
      var fA=t<7?0:t<8?(t-7):t<10?1:1-(t-10)/3;
      if(fA<.01)return;
      cx.save();
      cx.globalAlpha=fA*.9;
      var fg=cx.createRadialGradient(W/2,H/2,0,W/2,H/2,500);
      fg.addColorStop(0,'rgba(255,255,255,1)'); fg.addColorStop(.08,'rgba(255,200,80,.8)'); fg.addColorStop(.35,'rgba(200,64,26,.25)'); fg.addColorStop(1,'rgba(0,0,0,0)');
      cx.fillStyle=fg; cx.fillRect(0,0,W,H);
      // Anamorphic streak
      cx.globalAlpha=fA*.55;
      var streak=cx.createLinearGradient(0,H/2,W,H/2);
      streak.addColorStop(0,'rgba(0,0,0,0)'); streak.addColorStop(.42,'rgba(0,190,255,0)'); streak.addColorStop(.5,'rgba(0,190,255,.65)'); streak.addColorStop(.58,'rgba(0,190,255,0)'); streak.addColorStop(1,'rgba(0,0,0,0)');
      cx.fillStyle=streak; cx.fillRect(0,H/2-4,W,8);
      cx.restore();
    }

    function drawScanlines(){
      // Subtle scanline texture during chaos
      if(t<8||t>24)return;
      var sA=clamp((t-8)/2,0,1)*clamp(1-(t-20)/4,0,1)*.12;
      cx.save(); cx.globalAlpha=sA;
      cx.fillStyle='rgba(0,0,0,1)';
      for(var _sl=0;_sl<H;_sl+=4)cx.fillRect(0,_sl,W,2);
      cx.restore();
    }

    function drawVignette(){
      // Pre-cached — zero gradient recalculation per frame
      cx.drawImage(vigCv,0,0);
    }

    // ═══ UPDATE ══════════════════════════════════

    function updateCam(){
      var tx=0,ty=0,trx=0,try2=0;
      if(t<3){ cam.z=-1200; }
      else if(t<7){ cam.z=-1200+easeOut((t-3)/4)*2200; trx=Math.sin(t*.55)*.06; try2=Math.cos(t*.35)*.06; }
      else if(t<10){ cam.z=1000+(t-7)/3*600; trx=(Math.random()-.5)*.12; try2=(Math.random()-.5)*.12; }
      else if(t<22){ cam.z=1600+(t-10)/12*1000; trx=Math.sin(t*1.6)*.18; try2=Math.sin(t*.9)*.22; }
      else if(t<35){ cam.z=2600+Math.sin(t*.3)*250; trx=Math.sin(t*.55)*.09; try2=Math.sin(t*.35)*.12; }
      else if(t<45){ cam.z=2600-easeOut((t-35)/10)*1900; trx=cam.rx*.88; try2=cam.ry*.88; }
      else{ cam.z=700-clamp((t-45)/6,0,1)*120; trx=0; try2=0; }

      cam.rx+=(trx-cam.rx)*6*dt; cam.ry+=(try2-cam.ry)*6*dt;
      cam.shake*=.8;

      // Mouse parallax
      if(mouseX!==null){ cam.ry+=(mouseX/W-.5)*.12-cam.ry; cam.rx+=(mouseY/H-.5)*.07-cam.rx; }
    }

    function updateParticles(){
      var spd=1;
      if(t<7)spd=1+t/7*2.5;
      else if(t<10)spd=3.5+(t-7)/3*12;
      else if(t<14)spd=15.5-(t-10)/4*12;
      else if(t<35)spd=3.5;
      else if(t<45)spd=3.5-clamp((t-35)/10,0,1)*2.5;
      else spd=1;
      var zspd=spd*85;
      for(var _pi2=0;_pi2<particles.length;_pi2++){
        var p=particles[_pi2];
        p.z-=(p.bvz*zspd+p.vz)*dt; p.x+=p.vx*dt; p.y+=p.vy*dt;
        p.vx*=.975; p.vy*=.975; p.vz*=.975;
        if(p.z<cam.z+20){ p.z=cam.z+3500+Math.random()*1500; p.x=(Math.random()-.5)*5000; p.y=(Math.random()-.5)*4000; p.vx=p.vy=p.vz=0; }
        if(t>=7&&t<7.08){ p.vx+=(Math.random()-.5)*550; p.vy+=(Math.random()-.5)*550; p.vz+=(Math.random()-.5)*220; }
        if(t>=45){ p.vx+=(0-p.x)*.0008*dt; p.vy+=(0-p.y)*.0008*dt; }
      }
    }

    function updateRings(){
      // Spawn rings in chaos phase
      if(t>=10&&t<22){ var bucket=Math.floor(t*2.5); if(bucket!==Math.floor((t-dt)*2.5)) spawnRing((Math.random()-.5)*900,(Math.random()-.5)*500,200+Math.random()*500,Math.random()<.5?[0,190,255]:[200,64,26]); }
    }

    // ═══ MAIN FRAME ══════════════════════════════
    function frame(){
      drawBg();
      drawRings();
      drawGeos();
      drawParticles();
      drawDebris();
      drawFlashes();
      drawLogo();
      drawFlare();
      drawScanlines();

      // ── Bloom pass ───────────────────────────
      // Downscale the current frame into the 1/4-size bloom canvas, then composite
      // back at full size with 'screen' blend — the upscaling IS the blur (free bloom).
      blmCx.drawImage(cv, 0, 0, blmW, blmH);
      cx.save();
      cx.globalCompositeOperation='screen';
      cx.globalAlpha=.32;
      cx.drawImage(blmCv, 0, 0, W, H); // upscaling to W×H = implicit blur
      cx.globalAlpha=.16;
      // Second softer pass at half-size for wider halo
      cx.drawImage(blmCv, -W*.04, -H*.04, W*1.08, H*1.08);
      cx.restore();

      // ── Cinematic colour grade ────────────────
      // Warm the shadows, cool the highlights for a premium film look
      cx.save();
      var cg=cx.createLinearGradient(0,0,0,H);
      cg.addColorStop(0,'rgba(0,15,35,.08)');   // teal-blue highlights
      cg.addColorStop(.5,'rgba(0,0,0,0)');
      cg.addColorStop(1,'rgba(30,8,0,.1)');     // warm amber shadows
      cx.globalCompositeOperation='source-over';
      cx.fillStyle=cg; cx.fillRect(0,0,W,H);
      cx.restore();

      drawVignette();

      // Grain
      grainIdx=(grainIdx+1)%GN; cx.drawImage(grains[grainIdx],0,0);

      // Fade in from black
      if(t<1){ cx.save(); cx.globalAlpha=1-t; cx.fillStyle='#000'; cx.fillRect(0,0,W,H); cx.restore(); }

      // CTA
      var ctaEl=document.getElementById('fiftyCinemaCtaBtn');
      if(ctaEl) ctaEl.classList.toggle('show',t>=53);
    }

    function tick(ts){
      if(!playing)return;
      dt=lastTs!==null?Math.min((ts-lastTs)/1000,.05):.016; lastTs=ts;
      t+=dt;
      if(t>=7&&!boomDone){ boomDone=true; triggerBoom(); }
      updateCam(); updateParticles(); updateRings();
      frame();
      if(t>=LOOP){ t=0; boomDone=false; debris=[]; rings=[]; lastTs=null; }
      requestAnimationFrame(tick);
    }

    window.fiftyPlayCinema=function(){
      if(started)return; started=true;
      var ov=document.getElementById('fiftyCinemaOverlay');
      if(ov)ov.classList.add('fc-hidden');
      playing=true; requestAnimationFrame(tick);
    };
    window.fiftyCloseCinema=function(){};

    // Static preview — drawn at full DPR quality
    (function initPreview(){
      cx.fillStyle='#000'; cx.fillRect(0,0,W,H);
      var pg=cx.createRadialGradient(W/2,H/2,0,W/2,H/2,H*.75);
      pg.addColorStop(0,'rgba(200,64,26,.16)'); pg.addColorStop(.5,'rgba(0,60,140,.06)'); pg.addColorStop(1,'rgba(0,0,0,0)');
      cx.fillStyle=pg; cx.fillRect(0,0,W,H);
      // Logo — multi-pass glow for crisp retina render
      cx.textAlign='center'; cx.textBaseline='middle';
      cx.font='900 228px "Playfair Display",Georgia,serif';
      cx.shadowColor='rgba(200,64,26,.7)'; cx.shadowBlur=120;
      cx.globalAlpha=.3; cx.fillStyle='#fff'; cx.fillText('Fifty.',W/2,H/2);
      cx.shadowBlur=55; cx.globalAlpha=1;    cx.fillText('Fifty.',W/2,H/2);
      cx.shadowBlur=0;
      cx.globalAlpha=.38; cx.fillStyle='rgba(255,255,255,1)';
      cx.font='300 23px "DM Mono",monospace';
      cx.fillText('£50 A MONTH  ·  PROFESSIONALLY DESIGNED  ·  FULLY HOSTED',W/2,H/2+114);
      cx.globalAlpha=1;
      cx.drawImage(vigCv,0,0);
    })();

    // Mouse tracking
    var _wrap=document.getElementById('fiftyCinemaWrap');
    if(_wrap){
      _wrap.addEventListener('mousemove',function(e){var r=_wrap.getBoundingClientRect();mouseX=(e.clientX-r.left)/r.width*W;mouseY=(e.clientY-r.top)/r.height*H;});
      _wrap.addEventListener('mouseleave',function(){mouseX=mouseY=null;});
    }

    // Auto-play on scroll
    if('IntersectionObserver' in window){
      new IntersectionObserver(function(e){if(e[0].isIntersecting)fiftyPlayCinema();},{threshold:.3}).observe(_wrap||cv);
    }
  })();
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (fiftyCartIsOpen) { fiftyCloseCart(); return; }
      if (fiftyAccountIsOpen) { fiftyCloseAccount(); return; }
