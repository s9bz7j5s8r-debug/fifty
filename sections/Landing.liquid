  .fifty-scene-4 .fifty-panel-right .fifty-panel-label { color: var(--accent); }
  .fifty-scene-4 .fifty-panel-content { text-align: center; }
  .fifty-scene-4 .fifty-panel-content h3 { font-family: 'Playfair Display', serif; font-size: clamp(1.4rem, 2.8vw, 2.4rem); font-weight: 900; line-height: 1.2; letter-spacing: -0.02em; }
  .fifty-scene-4 .fifty-panel-left h3 { color: rgba(255,255,255,0.5); }
