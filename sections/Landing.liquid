  .fifty-scene-4 .fifty-panel-right p { color: var(--muted); }
  .fifty-scene-5 { background: #000; }
  .fifty-scene-5 .fifty-tagline { font-family: 'Playfair Display', serif; font-size: clamp(2.5rem, 7vw, 6rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.02em; color: white; }
  .fifty-scene-5 .fifty-tagline em { font-style: italic; color: var(--accent); }
  .fifty-scene-5 .fifty-tagline span { display: block; opacity: 0; transform: translateY(20px); transition: opacity 0.7s, transform 0.7s; }
  .fifty-scene-5.active .fifty-tagline span:nth-child(1) { opacity: 1; transform: none; transition-delay: 0.2s; }
  .fifty-scene-5.active .fifty-tagline span:nth-child(2) { opacity: 1; transform: none; transition-delay: 0.9s; }
  .fifty-scene-5.active .fifty-tagline span:nth-child(3) { opacity: 1; transform: none; transition-delay: 1.6s; }
  .fifty-scene-6 { background: radial-gradient(ellipse at center, #1a0a05 0%, #000 70%); }
  .fifty-scene-6 .fifty-end-logo { font-family: 'Playfair Display', serif; font-size: clamp(5rem, 14vw, 12rem); font-weight: 900; letter-spacing: -0.04em; color: white; line-height: 1; }
  .fifty-scene-6 .fifty-end-logo span { color: var(--accent); }
  .fifty-scene-6 .fifty-end-price { font-family: 'DM Mono', monospace; font-size: 0.9rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-top: 1.5rem; }
  .fifty-scene-6 .fifty-end-cta { display: inline-block; margin-top: 2.5rem; padding: 1rem 2.5rem; background: var(--accent); color: white; text-decoration: none; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; border-radius: 2px; transition: transform 0.2s; cursor: pointer; border: none; font-family: 'DM Mono', monospace; }
  .fifty-scene-6 .fifty-end-cta:hover { transform: translateY(-3px); }
  .fifty-cinema-progress { position: absolute; bottom: 3vh; left: 50%; transform: translateX(-50%); width: min(600px, 50vw); height: 2px; background: rgba(255,255,255,0.1); z-index: 15; border-radius: 2px; overflow: hidden; }
  .fifty-cinema-progress-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.1s linear; }

  /* FEATURES */
  .fifty-features { background: var(--white); }
  .fifty-features-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .fifty-features-left { position: sticky; top: 6rem; }
  .fifty-features-right { display: flex; flex-direction: column; }
  .fifty-feature-item { border-top: 1px solid var(--border); padding: 1.8rem 0; display: grid; grid-template-columns: 2.5rem 1fr; gap: 1rem; }
  .fifty-feature-item:last-child { border-bottom: 1px solid var(--border); }
  .fifty-feature-num { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--accent); font-style: italic; padding-top: 0.1rem; }
  .fifty-feature-name { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.4rem; }
  .fifty-feature-desc { color: var(--muted); font-size: 0.82rem; line-height: 1.65; }

  /* PORTFOLIO */
  .fifty-portfolio { background: var(--paper); padding-top: 4rem; padding-bottom: 8rem; }
  .fifty-portfolio-head { max-width: 1200px; margin: 0 auto 3rem; display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; flex-wrap: wrap; }
  .fifty-portfolio-head-text { max-width: 580px; }
  .fifty-portfolio-hint { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.5rem; }
  .fifty-portfolio-hint::before { content: '↘'; color: var(--accent); font-size: 1rem; }
  .fifty-portfolio-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .fifty-portfolio-card { cursor: pointer; position: relative; overflow: hidden; border-radius: 4px; background: var(--ink); transition: transform 0.4s cubic-bezier(0.2,0.8,0.2,1), box-shadow 0.4s; }
  .fifty-portfolio-card:hover { transform: translateY(-8px); box-shadow: 0 25px 50px rgba(13,13,13,0.2); }
  .fifty-portfolio-mockup { width: 100%; display: block; }
  .fifty-portfolio-card-meta { padding: 1.2rem 1.4rem; background: var(--white); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .fifty-portfolio-card-name { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1rem; }
  .fifty-portfolio-card-tag { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
  .fifty-portfolio-card::after { content: 'View'; position: absolute; top: 1rem; right: 1rem; background: var(--accent); color: white; padding: 0.4rem 0.9rem; border-radius: 100px; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 600; opacity: 0; transform: translateY(-4px); transition: opacity 0.3s, transform 0.3s; z-index: 5; }
  .fifty-portfolio-card:hover::after { opacity: 1; transform: none; }

  /* LIGHTBOX */
  .fifty-lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 1500; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
  .fifty-lightbox.active { opacity: 1; pointer-events: all; }
  .fifty-lightbox-content { max-width: 1100px; width: 100%; position: relative; }
  .fifty-lightbox-mockup svg { width: 100%; height: auto; max-height: 80vh; display: block; }
  .fifty-lightbox-info { position: absolute; bottom: -3rem; left: 0; color: rgba(255,255,255,0.7); font-size: 0.85rem; }
  .fifty-lightbox-info strong { font-family: 'Playfair Display', serif; font-weight: 700; color: white; margin-right: 0.6rem; }
  .fifty-lightbox-close { position: absolute; top: -3rem; right: 0; background: rgba(255,255,255,0.1); color: white; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; font-size: 1.2rem; }
  .fifty-lightbox-close:hover { background: rgba(255,255,255,0.2); }
  .fifty-lightbox-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.1); color: white; border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; font-size: 1.3rem; transition: background 0.2s; z-index: 10; }
  .fifty-lightbox-nav:hover { background: rgba(255,255,255,0.2); }
  .fifty-lightbox-prev { left: 2rem; }
  .fifty-lightbox-next { right: 2rem; }

  /* PRICING */
  .fifty-pricing { background: var(--paper); }
  .fifty-pricing-inner { max-width: 900px; margin: 0 auto; text-align: center; }
  .fifty-pricing-inner .fifty-section-title { margin: 0 auto 1rem; }
  .fifty-pricing-sub { color: var(--muted); margin-bottom: 3.5rem; font-size: 0.88rem; }
  .fifty-plan-card { background: var(--ink); color: var(--paper); border-radius: 4px; padding: 3.5rem; position: relative; overflow: hidden; text-align: left; }
  .fifty-plan-card::before { content: '£50'; position: absolute; right: -1rem; top: -2rem; font-family: 'Playfair Display', serif; font-size: 12rem; font-weight: 900; color: rgba(255,255,255,0.04); line-height: 1; pointer-events: none; }
  .fifty-plan-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
  .fifty-plan-name { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 900; }
  .fifty-plan-badge { background: var(--accent); color: white; font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 2px; }
  .fifty-plan-price-row { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.5rem; }
  .fifty-plan-price-big { font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 900; line-height: 1; }
  .fifty-plan-price-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); letter-spacing: 0.1em; }
  .fifty-plan-includes { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 2rem; }
  .fifty-plan-items { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem 2rem; list-style: none; margin-bottom: 2.5rem; }
  .fifty-plan-items li { font-size: 0.82rem; color: rgba(255,255,255,0.8); display: flex; align-items: center; gap: 0.6rem; }
  .fifty-plan-items li::before { content: '✓'; color: var(--accent); font-weight: 700; }
  .fifty-plan-cta { background: var(--paper); color: var(--ink); padding: 1rem 2.5rem; border: none; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: background 0.2s, color 0.2s; display: inline-block; }
  .fifty-plan-cta:hover { background: var(--accent); color: white; }

  /* PROCESS */
  .fifty-process { background: var(--white); }
  .fifty-process-inner { max-width: 1100px; margin: 0 auto; }
  .fifty-process-grid { display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 3.5rem; }
  .fifty-process-step { padding: 2rem; border-left: 1px solid var(--border); }
  .fifty-process-step:first-child { border-left: none; }
  .fifty-step-num { font-family: 'Playfair Display', serif; font-size: 3.5rem; font-weight: 900; color: var(--border); line-height: 1; margin-bottom: 1rem; }
  .fifty-step-title { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; }
  .fifty-step-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.65; }

  /* FAQ */
  .fifty-faq { background: var(--paper); }
  .fifty-faq-inner { max-width: 700px; margin: 0 auto; }
  .fifty-faq-inner .fifty-section-title { margin-bottom: 2.5rem; }
  .fifty-faq-item { border-top: 1px solid var(--border); }
  .fifty-faq-item:last-child { border-bottom: 1px solid var(--border); }
  .fifty-faq-q { width: 100%; background: none; border: none; padding: 1.4rem 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--ink); text-align: left; gap: 1rem; }
  .fifty-faq-icon { width: 24px; height: 24px; border: 1px solid var(--border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; transition: transform 0.3s, background 0.2s; color: var(--muted); flex-shrink: 0; }
  .fifty-faq-item.open .fifty-faq-icon { transform: rotate(45deg); background: var(--accent); border-color: var(--accent); color: white; }
  .fifty-faq-a { max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s; font-size: 0.85rem; color: var(--muted); line-height: 1.75; }
  .fifty-faq-item.open .fifty-faq-a { max-height: 300px; padding-bottom: 1.4rem; }

  /* CTA BAND */
  .fifty-cta-band { background: var(--accent); padding: 5rem 2.5rem; text-align: center; }
  .fifty-cta-band h2 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: white; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .fifty-cta-band p { color: rgba(255,255,255,0.75); margin-bottom: 2rem; font-size: 0.9rem; }
  .fifty-btn-white { background: white; color: var(--accent); padding: 0.9rem 2.5rem; border: none; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: transform 0.2s; display: inline-block; }
  .fifty-btn-white:hover { transform: translateY(-3px); }

  /* MODAL */
  .fifty-modal-overlay { position: fixed; inset: 0; background: rgba(13,13,13,0.8); z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
  .fifty-modal-overlay.active { opacity: 1; pointer-events: all; }
  .fifty-modal { background: var(--white); border-radius: 4px; padding: 3rem; max-width: 520px; width: 100%; transform: translateY(2rem); transition: transform 0.3s; }
  .fifty-modal-overlay.active .fifty-modal { transform: translateY(0); }
  .fifty-modal h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 900; margin-bottom: 0.5rem; color: var(--ink); }
  .fifty-modal p { color: var(--muted); font-size: 0.83rem; margin-bottom: 1.5rem; }
  .fifty-modal-close { float: right; background: none; border: none; font-size: 1.3rem; cursor: pointer; color: var(--muted); margin-top: -0.5rem; }
  .fifty-form-group { margin-bottom: 1.2rem; }
  .fifty-form-group label { display: block; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.4rem; color: var(--muted); }
  .fifty-form-group input, .fifty-form-group textarea { width: 100%; padding: 0.75rem 1rem; background: var(--paper); border: 1px solid var(--border); border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.83rem; color: var(--ink); outline: none; }
  .fifty-form-group input:focus, .fifty-form-group textarea:focus { border-color: var(--ink); }
  .fifty-form-group textarea { resize: vertical; min-height: 80px; }
  .fifty-form-submit { width: 100%; background: var(--ink); color: var(--paper); border: none; padding: 0.9rem; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; border-radius: 2px; cursor: pointer; }
  .fifty-form-submit:hover { background: var(--accent); }

  /* ANIMATIONS */
  @keyframes fifty-fadeUp { from{opacity:0; transform: translateY(1.5rem);} to{opacity:1; transform: none;} }
  .fifty-reveal { opacity: 0; transform: translateY(2rem); transition: opacity 0.7s ease, transform 0.7s ease; }
  .fifty-reveal.visible { opacity: 1; transform: none; }

  /* RESPONSIVE */
  @media (max-width: 900px) { .fifty-portfolio-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .fifty-features-inner { grid-template-columns: 1fr; }
    .fifty-features-left { position: static; }
    .fifty-process-grid { grid-template-columns: 1fr 1fr; }
    .fifty-plan-items { grid-template-columns: 1fr; }
    .fifty-portfolio-grid { grid-template-columns: 1fr; }
    .fifty-scene-4 .fifty-split { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; }
  }
  @media (max-width: 480px) { .fifty-section { padding: 4rem 1.5rem; } .fifty-process-grid { grid-template-columns: 1fr; } }
