  });

  // ── CART DRAWER ──────────────────────────────────────────────
  // Variant IDs that form the locked bundle (subscription + setup fee)
  var FIFTY_BUNDLE_VIDS = [53809850089811, 53809949933907];
  var fiftyCartIsOpen = false;

  function fiftyOpenCart() {
    fiftyCartIsOpen = true;
    fiftyCloseAccount();
    document.getElementById('fiftyCartDrawer').classList.add('open');
    document.getElementById('fiftyCartOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
    fiftyLoadCart();
  }

  function fiftyCloseCart() {
    fiftyCartIsOpen = false;
    document.getElementById('fiftyCartDrawer').classList.remove('open');
    document.getElementById('fiftyCartOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  function fiftyFmt(pence) {
    return '£' + (pence / 100).toFixed(2);
  }

  function fiftyLoadCart() {
    var itemsEl = document.getElementById('fiftyCartItems');
    itemsEl.innerHTML = '<div class="fifty-cart-loading"><div class="fifty-cart-spinner"></div></div>';
    document.getElementById('fiftyCartFoot').style.display = 'none';

    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) { fiftyRenderCart(cart); })
      .catch(function() {
        itemsEl.innerHTML = '<div class="fifty-cart-empty"><div class="fifty-cart-empty-title">Couldn\'t load cart</div><div class="fifty-cart-empty-sub">Please refresh the page and try again.</div></div>';
      });
  }

  function fiftyRenderCart(cart) {
    var itemsEl = document.getElementById('fiftyCartItems');
    var footEl  = document.getElementById('fiftyCartFoot');
    var pill    = document.getElementById('fiftyCartCountPill');
    var badge   = document.getElementById('fiftyCartBadge');
    var count   = cart.item_count || 0;

    // Update badge + pill
    pill.textContent = count;
    badge.textContent = count;
    if (count > 0) badge.classList.add('show');
    else badge.classList.remove('show');

    if (count === 0) {
      itemsEl.innerHTML =
        '<div class="fifty-cart-empty">' +
          '<div class="fifty-cart-empty-bag"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>' +
          '<div class="fifty-cart-empty-title">Your cart is empty.</div>' +
          '<div class="fifty-cart-empty-sub">No items yet. Start by choosing your plan.</div>' +
          '<a href="/products/fifty-website-subscription" class="fifty-cart-empty-cta" onclick="fiftyCloseCart()">Get Started →</a>' +
        '</div>';
      footEl.style.display = 'none';
      return;
    }

    // Split items: bundle (subscription + setup fee) vs standalone (logo etc)
    var bundleItems = [], otherItems = [];
    cart.items.forEach(function(item) {
      if (FIFTY_BUNDLE_VIDS.indexOf(item.variant_id) !== -1) bundleItems.push(item);
      else otherItems.push(item);
    });

    var html = '';

    // ── Bundle block ──
    if (bundleItems.length > 0) {
      var bundleTotal = bundleItems.reduce(function(s, i) { return s + i.line_price; }, 0);
      var bundleArgKeys = bundleItems.map(function(i) { return "'" + i.key + "'"; }).join(',');

      html += '<div class="fifty-cart-bundle">';
      html +=   '<div class="fifty-cart-bundle-top">';
      html +=     '<span class="fifty-cart-bundle-badge">Bundle</span>';
      html +=     '<span class="fifty-cart-bundle-name">The Fifty Plan</span>';
      html +=   '</div>';
      html +=   '<div class="fifty-cart-bundle-lines">';
      bundleItems.forEach(function(item) {
        html += '<div class="fifty-cart-bundle-line">';
        html +=   '<span class="fifty-cart-bundle-line-name">' + (item.product_title || item.title) + '</span>';
        html +=   '<span class="fifty-cart-bundle-line-price">' + fiftyFmt(item.line_price) + '</span>';
        html += '</div>';
      });
      html +=   '</div>';
      html +=   '<div class="fifty-cart-bundle-foot">';
      html +=     '<span class="fifty-cart-bundle-total-label">Bundle total</span>';
      html +=     '<div class="fifty-cart-bundle-total-right">';
      html +=       '<span class="fifty-cart-bundle-total">' + fiftyFmt(bundleTotal) + '</span>';
      html +=       '<button class="fifty-cart-item-remove" onclick="fiftyRemoveBundleKeys(' + bundleArgKeys + ')" title="Remove plan" aria-label="Remove plan">✕</button>';
      html +=     '</div>';
      html +=   '</div>';
      html += '</div>';
    }

    // ── Standalone items (logo add-on, etc) ──
    otherItems.forEach(function(item) {
      var imgHtml = item.image
        ? '<img src="' + item.image + '" alt="' + (item.title || '').replace(/"/g, '&quot;') + '" loading="lazy">'
        : '<span class="fifty-cart-item-placeholder">F.</span>';
      var varHtml = (item.variant_title && item.variant_title !== 'Default Title')
        ? '<div class="fifty-cart-item-variant">' + item.variant_title + '</div>' : '';

      html +=
        '<div class="fifty-cart-item" data-key="' + item.key + '">' +
          '<div class="fifty-cart-item-img">' + imgHtml + '</div>' +
          '<div class="fifty-cart-item-body">' +
            '<div class="fifty-cart-item-title">' + (item.product_title || item.title) + '</div>' +
            varHtml +
            '<div class="fifty-cart-item-row">' +
              '<div class="fifty-cart-qty">' +
                '<button class="fifty-cart-qty-btn" onclick="fiftyUpdateQty(\'' + item.key + '\',' + (item.quantity - 1) + ')" aria-label="Decrease">−</button>' +
                '<span class="fifty-cart-qty-num">' + item.quantity + '</span>' +
                '<button class="fifty-cart-qty-btn" onclick="fiftyUpdateQty(\'' + item.key + '\',' + (item.quantity + 1) + ')" aria-label="Increase">+</button>' +
              '</div>' +
              '<div class="fifty-cart-item-right">' +
                '<span class="fifty-cart-item-price">' + fiftyFmt(item.line_price) + '</span>' +
                '<button class="fifty-cart-item-remove" onclick="fiftyUpdateQty(\'' + item.key + '\',0)" title="Remove" aria-label="Remove">✕</button>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
    });

    itemsEl.innerHTML = html;

    // Update footer
    footEl.innerHTML =
      '<div class="fifty-cart-subtotal-row">' +
        '<span class="fifty-cart-subtotal-label">Due Today</span>' +
        '<span class="fifty-cart-subtotal-amount">' + fiftyFmt(cart.total_price) + '</span>' +
      '</div>' +
      '<p class="fifty-cart-foot-note">Includes first month + setup fee. Subscription renews at £50/month. Cancel any time.</p>' +
      '<a href="/checkout" class="fifty-cart-checkout">Proceed to Checkout &nbsp;→</a>' +
      '<button class="fifty-cart-continue" onclick="fiftyCloseCart()">← Continue Shopping</button>';
    footEl.style.display = 'block';
  }

  function fiftyUpdateQty(key, qty) {
    var itemEl = document.querySelector('.fifty-cart-item[data-key="' + key + '"]');
    if (itemEl) itemEl.style.opacity = '0.4';
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(function(cart) { fiftyRenderCart(cart); })
    .catch(function() { fiftyLoadCart(); });
  }

  // Remove all bundle items atomically — subscription + setup fee go together
  function fiftyRemoveBundleKeys() {
    var keys = Array.prototype.slice.call(arguments).filter(function(k) { return k && k.length > 0; });
    if (!keys.length) return;
    // Optimistic fade
    var bundle = document.querySelector('.fifty-cart-bundle');
    if (bundle) bundle.style.opacity = '0.4';
    var updates = {};
    keys.forEach(function(k) { updates[k] = 0; });
    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ updates: updates })
    })
    .then(function(r) { return r.json(); })
    .then(function(cart) { fiftyRenderCart(cart); })
    .catch(function() { fiftyLoadCart(); });
  }

  // ── ACCOUNT DROPDOWN ──────────────────────────────────────────
  var fiftyAccountIsOpen = false;

  function fiftyToggleAccount() {
    if (fiftyAccountIsOpen) fiftyCloseAccount();
    else fiftyOpenAccount();
  }

  function fiftyOpenAccount() {
    fiftyAccountIsOpen = true;
    document.getElementById('fiftyAccountDrop').classList.add('open');
    document.getElementById('fiftyAccountBtn').setAttribute('aria-expanded', 'true');
  }

  function fiftyCloseAccount() {
    fiftyAccountIsOpen = false;
    var drop = document.getElementById('fiftyAccountDrop');
    if (drop) drop.classList.remove('open');
    var btn = document.getElementById('fiftyAccountBtn');
    if (btn) btn.setAttribute('aria-expanded', 'false');
  }

  // Close account on outside click
  document.addEventListener('click', function(e) {
    if (!fiftyAccountIsOpen) return;
    var btn = document.getElementById('fiftyAccountBtn');
    var drop = document.getElementById('fiftyAccountDrop');
    if (btn && !btn.contains(e.target) && drop && !drop.contains(e.target)) {
      fiftyCloseAccount();
    }
  });
</script>

