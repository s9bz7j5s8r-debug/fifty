<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Mono:wght@300;400;500&family=Bebas+Neue&display=swap" rel="stylesheet">

{% style %}
  /* Hide the default Shopify header + footer on this page */
  #header-group, footer { display: none !important; }

  html { scroll-behavior: smooth; scroll-padding-top: 80px; }

  /* Custom fixed nav */
  .fifty-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; justify-content: space-between; padding: 1.2rem 2.5rem; background: var(--paper); border-bottom: 1px solid var(--border); }
  .fifty-nav-logo { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 900; letter-spacing: -0.03em; color: var(--ink); text-decoration: none; }
  .fifty-nav-logo span { color: var(--accent); }
  .fifty-nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
  .fifty-nav-links a { color: var(--muted); text-decoration: none; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s; font-family: 'DM Mono', monospace; }
  .fifty-nav-links a:hover { color: var(--ink); }
  .fifty-nav-cta { background: var(--ink) !important; color: var(--paper) !important; padding: 0.5rem 1.2rem; border-radius: 2px; }
  .fifty-nav-cta:hover { background: var(--accent) !important; color: var(--paper) !important; }
  .fifty-nav-btn { background: none; border: none; cursor: pointer; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); transition: color 0.2s; padding: 0; }
  .fifty-nav-btn:hover { color: var(--ink); }

  /* T&C MODAL */
  .fifty-tc-overlay { position: fixed; inset: 0; background: rgba(13,13,13,0.88); z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.35s; }
  .fifty-tc-overlay.active { opacity: 1; pointer-events: all; }
  .fifty-tc-modal { background: var(--white); color: var(--ink); border-radius: 4px; max-width: 780px; width: 100%; max-height: 88vh; display: flex; flex-direction: column; transform: translateY(2rem); transition: transform 0.35s; }
  .fifty-tc-overlay.active .fifty-tc-modal { transform: translateY(0); }
  .fifty-tc-modal-header { padding: 2rem 2.8rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: flex-start; flex-shrink: 0; background: var(--white); border-radius: 4px 4px 0 0; }
  .fifty-tc-modal-header-text .fifty-tc-eyebrow { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem; }
  .fifty-tc-modal-header-text h2 { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 900; letter-spacing: -0.02em; color: var(--ink); line-height: 1.1; }
  .fifty-tc-modal-header-text p { font-size: 0.75rem; color: var(--muted); margin-top: 0.3rem; }
  .fifty-tc-close { background: rgba(0,0,0,0.06); border: 1px solid var(--border); color: var(--muted); width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s; margin-left: 1.5rem; }
  .fifty-tc-close:hover { background: rgba(0,0,0,0.1); color: var(--ink); }
  .fifty-tc-body { padding: 2rem 2.8rem; overflow-y: auto; flex: 1; }
  .fifty-tc-body h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--ink); margin: 2rem 0 0.6rem; }
  .fifty-tc-body h3:first-child { margin-top: 0; }
  .fifty-tc-body p { font-size: 0.82rem; color: #444; line-height: 1.8; margin-bottom: 0.8rem; }
  .fifty-tc-body ul { padding-left: 1.2rem; margin-bottom: 0.8rem; }
  .fifty-tc-body ul li { font-size: 0.82rem; color: #444; line-height: 1.8; margin-bottom: 0.3rem; }
  .fifty-tc-body strong { color: var(--ink); font-weight: 600; }
  .fifty-tc-divider { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }
  .fifty-tc-footer { padding: 1.4rem 2.8rem; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; background: var(--paper); border-radius: 0 0 4px 4px; flex-wrap: wrap; gap: 1rem; }
  .fifty-tc-footer p { font-size: 0.72rem; color: var(--muted); }
  .fifty-tc-footer-cta { background: var(--ink); color: var(--paper); border: none; padding: 0.7rem 1.8rem; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: background 0.2s; }
  .fifty-tc-footer-cta:hover { background: var(--accent); }
  @media (max-width: 640px) { .fifty-tc-modal-header, .fifty-tc-body, .fifty-tc-footer { padding-left: 1.4rem; padding-right: 1.4rem; } }

  /* PRICING MODAL */
  .fifty-pricing-overlay { position: fixed; inset: 0; background: rgba(13,13,13,0.85); z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.35s; }
  .fifty-pricing-overlay.active { opacity: 1; pointer-events: all; }
  .fifty-pricing-modal { background: var(--ink); color: var(--paper); border-radius: 4px; max-width: 760px; width: 100%; max-height: 90vh; overflow-y: auto; transform: translateY(2rem); transition: transform 0.35s; position: relative; }
  .fifty-pricing-overlay.active .fifty-pricing-modal { transform: translateY(0); }
  .fifty-pricing-modal-header { padding: 2.5rem 3rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: flex-start; }
  .fifty-pricing-modal-header .fifty-included-eyebrow { font-size: 0.68rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.6rem; }
  .fifty-pricing-modal-header h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.02em; color: white; }
  .fifty-pricing-modal-header h2 em { font-style: italic; color: var(--accent); }
  .fifty-pricing-modal-body { padding: 2.5rem 3rem; }
  .fifty-pricing-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.2rem; margin-bottom: 2rem; }
  .fifty-pricing-card { border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 1.8rem 1.6rem; position: relative; }
  .fifty-pricing-card.featured { border-color: var(--accent); background: rgba(200,64,26,0.08); }
  .fifty-pricing-card-tag { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.2rem; }
  .fifty-pricing-card.featured .fifty-pricing-card-tag { color: var(--accent); }
  .fifty-pricing-card-amount { font-family: 'Playfair Display', serif; font-size: 2.6rem; font-weight: 900; color: white; line-height: 1; margin-bottom: 0.3rem; }
  .fifty-pricing-card-period { font-size: 0.72rem; color: rgba(255,255,255,0.35); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1.4rem; }
  .fifty-pricing-card-desc { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.65; margin-bottom: 1.4rem; }
  .fifty-pricing-card-items { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .fifty-pricing-card-items li { font-size: 0.75rem; color: rgba(255,255,255,0.6); display: flex; align-items: flex-start; gap: 0.5rem; line-height: 1.5; }
  .fifty-pricing-card-items li::before { content: '✓'; color: var(--accent); font-weight: 700; flex-shrink: 0; margin-top: 0.05rem; }
  .fifty-pricing-note { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; padding: 1.4rem 1.6rem; font-size: 0.78rem; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 2rem; }
  .fifty-pricing-note strong { color: rgba(255,255,255,0.75); }
  .fifty-pricing-cta-row { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .fifty-pricing-cta-main { background: var(--accent); color: white; border: none; padding: 0.9rem 2.2rem; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: transform 0.2s; }
  .fifty-pricing-cta-main:hover { transform: translateY(-2px); }
  .fifty-pricing-cta-sec { background: none; color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.12); padding: 0.9rem 2rem; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: border-color 0.2s, color 0.2s; }
  .fifty-pricing-cta-sec:hover { border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.7); }
  @media (max-width: 640px) {
    .fifty-pricing-cards { grid-template-columns: 1fr; }
    .fifty-pricing-modal-header, .fifty-pricing-modal-body { padding-left: 1.5rem; padding-right: 1.5rem; }
  }

  /* WHAT'S INCLUDED MODAL */
  .fifty-included-overlay { position: fixed; inset: 0; background: rgba(13,13,13,0.85); z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.35s; }
  .fifty-included-overlay.active { opacity: 1; pointer-events: all; }
  .fifty-included-modal { background: var(--ink); color: var(--paper); border-radius: 4px; max-width: 820px; width: 100%; max-height: 90vh; overflow-y: auto; transform: translateY(2rem); transition: transform 0.35s; position: relative; }
  .fifty-included-overlay.active .fifty-included-modal { transform: translateY(0); }
  .fifty-included-header { padding: 2.5rem 3rem 0; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-start; }
  .fifty-included-header-text .fifty-included-eyebrow { font-size: 0.68rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.6rem; }
  .fifty-included-header-text h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.02em; color: white; }
  .fifty-included-header-text h2 em { font-style: italic; color: var(--accent); }
  .fifty-included-close { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.6); width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s, color 0.2s; margin-left: 1.5rem; margin-top: 0.2rem; }
  .fifty-included-close:hover { background: rgba(255,255,255,0.15); color: white; }
  .fifty-included-body { padding: 2rem 3rem; }
  .fifty-included-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .fifty-included-item { padding: 1.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.07); display: grid; grid-template-columns: 2.2rem 1fr; gap: 0.8rem; align-items: start; }
  .fifty-included-item:nth-child(odd) { padding-right: 2rem; border-right: 1px solid rgba(255,255,255,0.07); }
  .fifty-included-item:nth-child(even) { padding-left: 2rem; }
  .fifty-included-item:nth-last-child(-n+2) { border-bottom: none; }
  .fifty-included-num { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.95rem; color: var(--accent); padding-top: 0.1rem; }
  .fifty-included-name { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: white; margin-bottom: 0.3rem; }
  .fifty-included-desc { font-size: 0.78rem; color: rgba(255,255,255,0.45); line-height: 1.6; }
  .fifty-included-footer { margin: 0 3rem 2.5rem; padding: 1.8rem 2rem; background: rgba(200,64,26,0.12); border: 1px solid rgba(200,64,26,0.3); border-radius: 4px; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .fifty-included-price { display: flex; align-items: baseline; gap: 0.4rem; }
  .fifty-included-price-big { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 900; color: white; line-height: 1; }
  .fifty-included-price-label { font-size: 0.78rem; color: rgba(255,255,255,0.4); letter-spacing: 0.1em; text-transform: uppercase; }
  .fifty-included-footer-text { font-size: 0.8rem; color: rgba(255,255,255,0.5); max-width: 280px; line-height: 1.6; }
  .fifty-included-footer-text strong { color: white; }
  .fifty-included-cta { background: var(--accent); color: white; border: none; padding: 0.85rem 2rem; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: transform 0.2s, background 0.2s; white-space: nowrap; }
  .fifty-included-cta:hover { transform: translateY(-2px); background: #e04d20; }
  @media (max-width: 640px) {
    .fifty-included-grid { grid-template-columns: 1fr; }
    .fifty-included-item:nth-child(odd) { padding-right: 0; border-right: none; }
    .fifty-included-item:nth-child(even) { padding-left: 0; }
    .fifty-included-item:nth-last-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.07); }
    .fifty-included-item:last-child { border-bottom: none; }
    .fifty-included-header, .fifty-included-body { padding-left: 1.5rem; padding-right: 1.5rem; }
    .fifty-included-footer { margin-left: 1.5rem; margin-right: 1.5rem; }
  }

  :root {
    --ink: #0d0d0d;
    --paper: #f5f0e8;
    --accent: #c8401a;
    --muted: #8a8070;
    --border: #d4cfc4;
    --white: #fefdfb;
  }

  .fifty-wrapper *, .fifty-wrapper *::before, .fifty-wrapper *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .fifty-wrapper { background: var(--paper); color: var(--ink); font-family: 'DM Mono', monospace; font-size: 14px; line-height: 1.7; overflow-x: hidden; }

  /* HERO */
  .fifty-hero { min-height: 100vh; display: grid; place-items: center; padding: 8rem 2.5rem 4rem; position: relative; overflow: hidden; }
  .fifty-hero-bg-text { position: absolute; font-family: 'Playfair Display', serif; font-size: clamp(10rem, 28vw, 28rem); font-weight: 900; color: transparent; -webkit-text-stroke: 1px var(--border); top: 50%; left: 50%; transform: translate(-50%, -50%); white-space: nowrap; pointer-events: none; user-select: none; letter-spacing: -0.05em; animation: fifty-float 8s ease-in-out infinite; }
  @keyframes fifty-float { 0%,100%{transform:translate(-50%,-50%) translateY(0);} 50%{transform:translate(-50%,-50%) translateY(-1.5rem);} }
  .fifty-hero-inner { position: relative; z-index: 1; max-width: 780px; text-align: center; }
  .fifty-hero-eyebrow { display: inline-block; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent); padding: 0.35rem 0.9rem; margin-bottom: 2rem; animation: fifty-fadeUp 0.8s ease both; }
  .fifty-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(3rem, 8vw, 6.5rem); font-weight: 900; line-height: 1.0; letter-spacing: -0.03em; margin-bottom: 1.5rem; animation: fifty-fadeUp 0.8s 0.15s ease both; }
  .fifty-hero h1 em { font-style: italic; color: var(--accent); }
  .fifty-hero-sub { font-size: 0.95rem; color: var(--muted); max-width: 500px; margin: 0 auto 2.5rem; animation: fifty-fadeUp 0.8s 0.3s ease both; }
  .fifty-hero-price { display: inline-flex; align-items: baseline; gap: 0.4rem; font-family: 'Playfair Display', serif; animation: fifty-fadeUp 0.8s 0.45s ease both; margin-bottom: 2.5rem; }
  .fifty-hero-price .pound { font-size: 2rem; font-weight: 700; color: var(--accent); }
  .fifty-hero-price .amount { font-size: 5rem; font-weight: 900; line-height: 1; }
  .fifty-hero-price .per { font-family: 'DM Mono', monospace; font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-left: 0.3rem; }
  .fifty-hero-ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; animation: fifty-fadeUp 0.8s 0.6s ease both; }

  /* BUTTONS */
  .fifty-btn-primary { background: var(--ink); color: var(--paper); padding: 0.9rem 2.2rem; border: none; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: background 0.2s, transform 0.15s; display: inline-block; }
  .fifty-btn-primary:hover { background: var(--accent); transform: translateY(-2px); }
  .fifty-btn-ghost { background: transparent; color: var(--ink); padding: 0.9rem 2.2rem; border: 1px solid var(--border); border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: border-color 0.2s; display: inline-block; }
  .fifty-btn-ghost:hover { border-color: var(--ink); }

  /* MARQUEE */
  .fifty-marquee-bar { background: var(--ink); color: var(--paper); padding: 0.75rem 0; overflow: hidden; white-space: nowrap; }
  .fifty-marquee-track { display: inline-flex; animation: fifty-marquee 25s linear infinite; gap: 3rem; font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; }
  .fifty-marquee-track span { color: var(--accent); margin-right: 1rem; }
  @keyframes fifty-marquee { 0%{transform:translateX(0);} 100%{transform:translateX(-50%);} }

  /* SECTION COMMON */
  .fifty-section { padding: 6rem 2.5rem; }
  .fifty-section-label { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }
  .fifty-section-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.02em; max-width: 580px; }
  .fifty-section-title em { font-style: italic; color: var(--accent); }

  /* BRAND ANIMATION SECTION */
  .fifty-brand-section { position: relative; background: #080808; overflow: hidden; min-height: 72vh; display: flex; align-items: center; justify-content: center; }
  .fifty-brand-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.028) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.028) 1px, transparent 1px); background-size: 64px 64px; pointer-events: none; }
  .fifty-brand-orb { position: absolute; border-radius: 50%; filter: blur(90px); animation: fbOrb linear infinite; pointer-events: none; }
  .fifty-brand-orb-1 { width: 650px; height: 650px; background: radial-gradient(circle, rgba(200,64,26,0.22) 0%, transparent 70%); top: -12%; left: -14%; animation-duration: 20s; }
  .fifty-brand-orb-2 { width: 520px; height: 520px; background: radial-gradient(circle, rgba(0,100,200,0.14) 0%, transparent 70%); bottom: -12%; right: -10%; animation-duration: 25s; animation-delay: -9s; }
  .fifty-brand-orb-3 { width: 380px; height: 380px; background: radial-gradient(circle, rgba(200,64,26,0.11) 0%, transparent 70%); top: 38%; right: 18%; animation-duration: 17s; animation-delay: -5s; }
  @keyframes fbOrb { 0%{transform:translate(0,0) scale(1);} 25%{transform:translate(45px,-35px) scale(1.06);} 50%{transform:translate(22px,42px) scale(0.96);} 75%{transform:translate(-32px,18px) scale(1.04);} 100%{transform:translate(0,0) scale(1);} }
  .fifty-brand-section::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, transparent 38%, rgba(0,0,0,0.65) 100%); pointer-events: none; z-index: 1; }
  .fifty-brand-content { position: relative; z-index: 2; text-align: center; padding: 6rem 2rem; }
  .fifty-brand-eyebrow { font-family: 'DM Mono', monospace; font-size: 0.63rem; letter-spacing: 0.38em; text-transform: uppercase; color: rgba(255,255,255,0.32); margin-bottom: 2rem; animation: fbUp 1s ease both; }
  .fifty-brand-logo { font-family: 'Playfair Display', serif; font-size: clamp(4.5rem, 13vw, 9.5rem); font-weight: 900; color: #fff; letter-spacing: -0.03em; line-height: 1; animation: fbUp 1s ease 0.15s both; text-shadow: 0 0 90px rgba(200,64,26,0.45), 0 0 180px rgba(200,64,26,0.18); }
  .fifty-brand-logo em { font-style: italic; color: #c8401a; }
  .fifty-brand-tagline { font-size: clamp(0.82rem, 1.8vw, 1rem); color: rgba(255,255,255,0.42); margin-top: 1.5rem; letter-spacing: 0.02em; line-height: 1.8; animation: fbUp 1s ease 0.3s both; }
  .fifty-brand-stats { display: flex; align-items: center; justify-content: center; gap: 3rem; margin-top: 3.2rem; animation: fbUp 1s ease 0.45s both; flex-wrap: wrap; }
  .fifty-brand-stat { text-align: center; }
  .fifty-brand-stat-val { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 900; color: white; line-height: 1; }
  .fifty-brand-stat-val em { font-style: italic; color: #c8401a; }
  .fifty-brand-stat-label { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.28); margin-top: 0.45rem; }
  .fifty-brand-divider { width: 1px; height: 38px; background: rgba(255,255,255,0.1); }
  .fifty-brand-cta { display: inline-flex; align-items: center; gap: 0.8rem; margin-top: 3.2rem; padding: 1rem 2.8rem; border: 1px solid rgba(200,64,26,0.65); color: white; text-decoration: none; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; transition: all 0.3s; border-radius: 2px; animation: fbUp 1s ease 0.6s both; background: rgba(200,64,26,0.06); box-shadow: 0 0 30px rgba(200,64,26,0.15), inset 0 0 20px rgba(200,64,26,0.04); }
  .fifty-brand-cta:hover { background: rgba(200,64,26,0.16); border-color: #c8401a; transform: translateY(-2px); box-shadow: 0 0 55px rgba(200,64,26,0.4), inset 0 0 30px rgba(200,64,26,0.08); color: white; }
  .fifty-brand-cta::after { content: '→'; opacity: 0.65; transition: transform 0.3s; }
  .fifty-brand-cta:hover::after { transform: translateX(5px); }
  @keyframes fbUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }

  /* WHY US */
  .fifty-why { background: var(--ink); color: var(--paper); padding: 7rem 2.5rem; position: relative; overflow: hidden; }
  .fifty-why::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 80px 80px; pointer-events: none; }
  .fifty-why-inner { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }
  .fifty-why-head { text-align: center; max-width: 680px; margin: 0 auto 5rem; }
  .fifty-why-head .fifty-section-label { color: var(--accent); }
  .fifty-why-head .fifty-why-title { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.03em; color: white; }
  .fifty-why-head .fifty-why-title em { font-style: italic; color: var(--accent); }
  .fifty-why-head .fifty-why-sub { font-size: 0.88rem; color: rgba(255,255,255,0.45); margin-top: 1.2rem; line-height: 1.8; max-width: 480px; margin-left: auto; margin-right: auto; }
  .fifty-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.07); border-radius: 4px; overflow: hidden; margin-bottom: 4rem; }
  .fifty-why-card { background: var(--ink); padding: 2.4rem 2rem; transition: background 0.3s; position: relative; }
  .fifty-why-card:hover { background: rgba(255,255,255,0.04); }
  .fifty-why-card-num { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-style: italic; color: var(--accent); margin-bottom: 1.2rem; letter-spacing: 0.05em; line-height: 1; }
  .fifty-why-card-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 900; color: white; line-height: 1.2; margin-bottom: 0.8rem; letter-spacing: -0.01em; }
  .fifty-why-card-body { font-size: 0.8rem; color: rgba(255,255,255,0.48); line-height: 1.75; }
  .fifty-why-card-body strong { color: rgba(255,255,255,0.8); font-weight: 500; }
  .fifty-why-compare { border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden; }
  .fifty-why-compare-header { display: grid; grid-template-columns: 1fr 1fr 1fr; background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08); }
  .fifty-why-compare-header div { padding: 0.9rem 1.4rem; font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .fifty-why-compare-header div:first-child { color: rgba(255,255,255,0.3); }
  .fifty-why-compare-header div:nth-child(2) { color: var(--accent); border-left: 1px solid rgba(255,255,255,0.08); border-right: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .fifty-why-compare-header div:last-child { color: rgba(255,255,255,0.3); text-align: center; }
  .fifty-why-compare-row { display: grid; grid-template-columns: 1fr 1fr 1fr; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .fifty-why-compare-row:last-child { border-bottom: none; }
  .fifty-why-compare-row div { padding: 0.95rem 1.4rem; font-size: 0.78rem; line-height: 1.5; }
  .fifty-why-compare-row div:first-child { color: rgba(255,255,255,0.55); }
  .fifty-why-compare-row div:nth-child(2) { border-left: 1px solid rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.05); background: rgba(200,64,26,0.06); text-align: center; color: rgba(255,255,255,0.85); }
  .fifty-why-compare-row div:last-child { text-align: center; color: rgba(255,255,255,0.3); }
  .fifty-why-tick { color: var(--accent); font-size: 1rem; }
  .fifty-why-cross { color: rgba(255,255,255,0.2); font-size: 1rem; }
  @media (max-width: 900px) { .fifty-why-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .fifty-why-grid { grid-template-columns: 1fr; } .fifty-why-compare-row div, .fifty-why-compare-header div { padding: 0.75rem 0.8rem; font-size: 0.72rem; } }
  .fifty-why-table-wrap { max-width: 900px; margin: 0 auto; overflow-x: auto; }
  .fifty-why-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .fifty-why-table thead tr { border-bottom: 1px solid rgba(255,255,255,0.12); }
  .fifty-why-table th { padding: 1rem 1.4rem; text-align: left; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.35); font-weight: 600; }
  .fifty-why-th-us { color: var(--accent) !important; }
  .fifty-why-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.2s; }
  .fifty-why-table tbody tr:last-child { border-bottom: none; }
  .fifty-why-table tbody tr:hover { background: rgba(255,255,255,0.03); }
  .fifty-why-table td { padding: 0.95rem 1.4rem; color: rgba(255,255,255,0.45); vertical-align: middle; }
  .fifty-why-table td:first-child { color: rgba(255,255,255,0.6); font-weight: 500; }
  .fifty-why-td-us { color: rgba(255,255,255,0.9) !important; background: rgba(200,64,26,0.08); font-weight: 600 !important; }
  @media (max-width: 700px) { .fifty-why-table th, .fifty-why-table td { padding: 0.75rem 0.9rem; font-size: 0.75rem; } }

  /* FEATURES */
  .fifty-features { background: var(--white); }
  .fifty-features-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .fifty-features-left { position: sticky; top: 6rem; }
  .fifty-features-right { display: flex; flex-direction: column; }
  .fifty-feature-item { border-top: 1px solid var(--border); padding: 1.8rem 0; display: grid; grid-template-columns: 2.5rem 1fr; gap: 1rem; }
  .fifty-feature-item:last-child { border-bottom: 1px solid var(--border); }
  .fifty-feature-num { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--accent); font-style: italic; padding-top: 0.1rem; }
  .fifty-feature-name { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.4rem; }
  .fifty-feature-desc { color: var(--muted); font-size: 0.82rem; line-height: 1.65; }

  /* PORTFOLIO */
  .fifty-portfolio { background: var(--paper); padding-top: 4rem; padding-bottom: 8rem; }
  .fifty-portfolio-head { max-width: 1200px; margin: 0 auto 3rem; display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; flex-wrap: wrap; }
  .fifty-portfolio-head-text { max-width: 580px; }
  .fifty-portfolio-hint { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.5rem; }
  .fifty-portfolio-hint::before { content: '↘'; color: var(--accent); font-size: 1rem; }
  .fifty-portfolio-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .fifty-portfolio-card { cursor: pointer; position: relative; overflow: hidden; border-radius: 4px; background: var(--ink); transition: transform 0.4s cubic-bezier(0.2,0.8,0.2,1), box-shadow 0.4s; }
  .fifty-portfolio-card:hover { transform: translateY(-8px); box-shadow: 0 25px 50px rgba(13,13,13,0.2); }
  .fifty-portfolio-mockup { width: 100%; display: block; }
  .fifty-portfolio-card-meta { padding: 1.2rem 1.4rem; background: var(--white); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .fifty-portfolio-card-name { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1rem; }
  .fifty-portfolio-card-tag { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
  .fifty-portfolio-card::after { content: 'View'; position: absolute; top: 1rem; right: 1rem; background: var(--accent); color: white; padding: 0.4rem 0.9rem; border-radius: 100px; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 600; opacity: 0; transform: translateY(-4px); transition: opacity 0.3s, transform 0.3s; z-index: 5; }
  .fifty-portfolio-card:hover::after { opacity: 1; transform: none; }

  /* LIGHTBOX */
  .fifty-lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 1500; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
  .fifty-lightbox.active { opacity: 1; pointer-events: all; }
  .fifty-lightbox-content { max-width: 1100px; width: 100%; position: relative; }
  .fifty-lightbox-mockup svg { width: 100%; height: auto; max-height: 80vh; display: block; }
  .fifty-lightbox-info { position: absolute; bottom: -3rem; left: 0; color: rgba(255,255,255,0.7); font-size: 0.85rem; }
  .fifty-lightbox-info strong { font-family: 'Playfair Display', serif; font-weight: 700; color: white; margin-right: 0.6rem; }
  .fifty-lightbox-close { position: absolute; top: -3rem; right: 0; background: rgba(255,255,255,0.1); color: white; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; font-size: 1.2rem; }
  .fifty-lightbox-close:hover { background: rgba(255,255,255,0.2); }
  .fifty-lightbox-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.1); color: white; border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; font-size: 1.3rem; transition: background 0.2s; z-index: 10; }
  .fifty-lightbox-nav:hover { background: rgba(255,255,255,0.2); }
  .fifty-lightbox-prev { left: 2rem; }
  .fifty-lightbox-next { right: 2rem; }

  /* PRICING */
  .fifty-pricing { background: var(--paper); }
  .fifty-pricing-inner { max-width: 900px; margin: 0 auto; text-align: center; }
  .fifty-pricing-inner .fifty-section-title { margin: 0 auto 1rem; }
  .fifty-pricing-sub { color: var(--muted); margin-bottom: 3.5rem; font-size: 0.88rem; }
  .fifty-plan-card { background: var(--ink); color: var(--paper); border-radius: 4px; padding: 3.5rem; position: relative; overflow: hidden; text-align: left; }
  .fifty-plan-card::before { content: '£50'; position: absolute; right: -1rem; top: -2rem; font-family: 'Playfair Display', serif; font-size: 12rem; font-weight: 900; color: rgba(255,255,255,0.04); line-height: 1; pointer-events: none; }
  .fifty-plan-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
  .fifty-plan-name { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 900; }
  .fifty-plan-badge { background: var(--accent); color: white; font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 2px; }
  .fifty-plan-price-row { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.5rem; }
  .fifty-plan-price-big { font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 900; line-height: 1; }
  .fifty-plan-price-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); letter-spacing: 0.1em; }
  .fifty-plan-includes { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 2rem; }
  .fifty-plan-items { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem 2rem; list-style: none; margin-bottom: 2.5rem; }
  .fifty-plan-items li { font-size: 0.82rem; color: rgba(255,255,255,0.8); display: flex; align-items: center; gap: 0.6rem; }
  .fifty-plan-items li::before { content: '✓'; color: var(--accent); font-weight: 700; }
  .fifty-plan-cta { background: var(--paper); color: var(--ink); padding: 1rem 2.5rem; border: none; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: background 0.2s, color 0.2s; display: inline-block; }
  .fifty-plan-cta:hover { background: var(--accent); color: white; }

  /* PROCESS */
  .fifty-process { background: var(--white); }
  .fifty-process-inner { max-width: 1100px; margin: 0 auto; }
  .fifty-process-grid { display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 3.5rem; }
  .fifty-process-step { padding: 2rem; border-left: 1px solid var(--border); }
  .fifty-process-step:first-child { border-left: none; }
  .fifty-step-num { font-family: 'Playfair Display', serif; font-size: 3.5rem; font-weight: 900; color: var(--border); line-height: 1; margin-bottom: 1rem; }
  .fifty-step-title { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; }
  .fifty-step-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.65; }

  /* FAQ */
  .fifty-faq { background: var(--paper); }
  .fifty-faq-inner { max-width: 700px; margin: 0 auto; }
  .fifty-faq-inner .fifty-section-title { margin-bottom: 2.5rem; }
  .fifty-faq-item { border-top: 1px solid var(--border); }
  .fifty-faq-item:last-child { border-bottom: 1px solid var(--border); }
  .fifty-faq-q { width: 100%; background: none; border: none; padding: 1.4rem 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--ink); text-align: left; gap: 1rem; }
  .fifty-faq-icon { width: 24px; height: 24px; border: 1px solid var(--border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; transition: transform 0.3s, background 0.2s; color: var(--muted); flex-shrink: 0; }
  .fifty-faq-item.open .fifty-faq-icon { transform: rotate(45deg); background: var(--accent); border-color: var(--accent); color: white; }
  .fifty-faq-a { max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s; font-size: 0.85rem; color: var(--muted); line-height: 1.75; }
  .fifty-faq-item.open .fifty-faq-a { max-height: 600px; padding-bottom: 1.4rem; }

  /* CTA BAND */
  .fifty-cta-band { background: var(--accent); padding: 5rem 2.5rem; text-align: center; }
  .fifty-cta-band h2 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: white; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .fifty-cta-band p { color: rgba(255,255,255,0.75); margin-bottom: 2rem; font-size: 0.9rem; }
  .fifty-btn-white { background: white; color: var(--accent); padding: 0.9rem 2.5rem; border: none; border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: transform 0.2s, background 0.2s; display: inline-block; }
  .fifty-btn-white:hover { transform: translateY(-3px); background: #f5f0e8; }

  /* MODAL */
  .fifty-modal-overlay { position: fixed; inset: 0; background: rgba(13,13,13,0.8); z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
  .fifty-modal-overlay.active { opacity: 1; pointer-events: all; }
  .fifty-modal { background: var(--white); border-radius: 4px; padding: 3rem; max-width: 520px; width: 100%; transform: translateY(2rem); transition: transform 0.3s; }
  .fifty-modal-overlay.active .fifty-modal { transform: translateY(0); }
  .fifty-modal h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 900; margin-bottom: 0.5rem; color: var(--ink); }
  .fifty-modal p { color: var(--muted); font-size: 0.83rem; margin-bottom: 1.5rem; }
  .fifty-modal-close { float: right; background: none; border: none; font-size: 1.3rem; cursor: pointer; color: var(--muted); margin-top: -0.5rem; }
  .fifty-form-group { margin-bottom: 1.2rem; }
  .fifty-form-group label { display: block; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.4rem; color: var(--muted); }
  .fifty-form-group input, .fifty-form-group textarea { width: 100%; padding: 0.75rem 1rem; background: var(--paper); border: 1px solid var(--border); border-radius: 2px; font-family: 'DM Mono', monospace; font-size: 0.83rem; color: var(--ink); outline: none; }
  .fifty-form-group input:focus, .fifty-form-group textarea:focus { border-color: var(--ink); }
  .fifty-form-group textarea { resize: vertical; min-height: 80px; }
  .fifty-form-submit { width: 100%; background: var(--ink); color: var(--paper); border: none; padding: 0.9rem; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; border-radius: 2px; cursor: pointer; }
  .fifty-form-submit:hover { background: var(--accent); }

  /* ANIMATIONS */
  @keyframes fifty-fadeUp { from{opacity:0; transform: translateY(1.5rem);} to{opacity:1; transform: none;} }
  .fifty-reveal { opacity: 0; transform: translateY(2rem); transition: opacity 0.7s ease, transform 0.7s ease; }
  .fifty-reveal.visible { opacity: 1; transform: none; }

  /* ── NAV ACTIONS (account + cart) ── */
  .fifty-nav-actions { display: flex; align-items: center; gap: 0.15rem; }
  .fifty-nav-icon-btn { position: relative; background: none; border: none; cursor: pointer; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; border-radius: 2px; transition: background 0.2s; color: var(--ink); padding: 0; flex-shrink: 0; }
  .fifty-nav-icon-btn:hover { background: rgba(13,13,13,0.07); }
  .fifty-nav-icon-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; pointer-events: none; }

  /* CART BADGE */
  .fifty-cart-badge { position: absolute; top: 2px; right: 2px; background: var(--accent); color: white; font-family: 'DM Mono', monospace; font-size: 0.5rem; font-weight: 700; min-width: 15px; height: 15px; border-radius: 8px; display: flex; align-items: center; justify-content: center; padding: 0 3px; pointer-events: none; transform: scale(0); transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1); line-height: 1; }
  .fifty-cart-badge.show { transform: scale(1); }

  /* ACCOUNT DROPDOWN */
  .fifty-account-wrap { position: relative; }
  .fifty-account-drop { position: absolute; top: calc(100% + 10px); right: 0; background: var(--white); border: 1px solid var(--border); border-radius: 3px; min-width: 215px; box-shadow: 0 16px 40px rgba(13,13,13,0.13), 0 2px 8px rgba(13,13,13,0.06); opacity: 0; pointer-events: none; transform: translateY(-6px) scale(0.98); transition: opacity 0.2s, transform 0.2s; z-index: 300; transform-origin: top right; }
  .fifty-account-drop::before { content: ''; position: absolute; top: -5px; right: 12px; width: 9px; height: 9px; background: var(--white); border-left: 1px solid var(--border); border-top: 1px solid var(--border); transform: rotate(45deg); }
  .fifty-account-drop.open { opacity: 1; pointer-events: all; transform: none; }
  .fifty-account-drop-head { padding: 1rem 1.2rem 0.8rem; border-bottom: 1px solid var(--border); }
  .fifty-account-drop-name { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: var(--ink); line-height: 1.2; }
  .fifty-account-drop-sub { font-size: 0.67rem; color: var(--muted); margin-top: 0.25rem; letter-spacing: 0.02em; }
  .fifty-account-drop-links { padding: 0.35rem 0; }
  .fifty-account-drop-link { display: flex; align-items: center; gap: 0.65rem; padding: 0.62rem 1.2rem; font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.07em; text-transform: uppercase; color: var(--ink); text-decoration: none; transition: background 0.15s, color 0.15s; cursor: pointer; background: none; border: none; width: 100%; text-align: left; }
  .fifty-account-drop-link:hover { background: var(--paper); color: var(--accent); }
  .fifty-account-drop-link svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
  .fifty-account-drop-divider { height: 1px; background: var(--border); margin: 0.3rem 0.8rem; }
  .fifty-account-drop-link.fifty-logout { color: var(--muted); }
  .fifty-account-drop-link.fifty-logout:hover { color: #b52a1a; background: rgba(181,42,26,0.04); }

  /* CART OVERLAY */
  .fifty-cart-overlay { position: fixed; inset: 0; background: rgba(13,13,13,0.52); z-index: 900; opacity: 0; pointer-events: none; transition: opacity 0.3s; backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px); }
  .fifty-cart-overlay.open { opacity: 1; pointer-events: all; }

  /* CART DRAWER */
  .fifty-cart-drawer { position: fixed; top: 0; right: 0; bottom: 0; width: 400px; max-width: 100vw; background: var(--ink); z-index: 1000; transform: translateX(100%); transition: transform 0.38s cubic-bezier(0.4,0,0.2,1); display: flex; flex-direction: column; box-shadow: -20px 0 60px rgba(0,0,0,0.3); }
  .fifty-cart-drawer.open { transform: none; }
  .fifty-cart-head { display: flex; align-items: center; justify-content: space-between; padding: 1.4rem 1.6rem; border-bottom: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
  .fifty-cart-head-left { display: flex; align-items: center; gap: 0.75rem; }
  .fifty-cart-title { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 900; color: white; letter-spacing: -0.02em; }
  .fifty-cart-count-pill { background: var(--accent); color: white; font-family: 'DM Mono', monospace; font-size: 0.6rem; font-weight: 700; padding: 0.18rem 0.55rem; border-radius: 100px; min-width: 22px; text-align: center; }
  .fifty-cart-close { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.45); width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; transition: background 0.2s, color 0.2s; flex-shrink: 0; }
  .fifty-cart-close:hover { background: rgba(255,255,255,0.12); color: white; }

  /* CART ITEMS (scrollable area) */
  .fifty-cart-items { flex: 1; overflow-y: auto; overscroll-behavior: contain; }
  .fifty-cart-items::-webkit-scrollbar { width: 3px; }
  .fifty-cart-items::-webkit-scrollbar-track { background: transparent; }
  .fifty-cart-items::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
  .fifty-cart-item { display: grid; grid-template-columns: 58px 1fr; gap: 1rem; padding: 1.1rem 1.6rem; border-bottom: 1px solid rgba(255,255,255,0.05); align-items: start; }
  .fifty-cart-item:last-child { border-bottom: none; }
  .fifty-cart-item-img { width: 58px; height: 58px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
  .fifty-cart-item-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fifty-cart-item-placeholder { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 900; color: var(--accent); font-style: italic; }
  .fifty-cart-item-body { min-width: 0; }
  .fifty-cart-item-title { font-family: 'Playfair Display', serif; font-size: 0.9rem; font-weight: 700; color: white; line-height: 1.3; margin-bottom: 0.2rem; }
  .fifty-cart-item-variant { font-size: 0.63rem; color: rgba(255,255,255,0.28); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.6rem; }
  .fifty-cart-item-row { display: flex; align-items: center; justify-content: space-between; }
  .fifty-cart-qty { display: flex; align-items: center; border: 1px solid rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
  .fifty-cart-qty-btn { background: none; border: none; color: rgba(255,255,255,0.45); width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 1rem; line-height: 1; transition: background 0.15s, color 0.15s; }
  .fifty-cart-qty-btn:hover { background: rgba(255,255,255,0.07); color: white; }
  .fifty-cart-qty-num { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: white; min-width: 26px; text-align: center; }
  .fifty-cart-item-right { display: flex; align-items: center; gap: 0.55rem; }
  .fifty-cart-item-price { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: white; }
  .fifty-cart-item-remove { background: none; border: none; color: rgba(255,255,255,0.18); cursor: pointer; font-size: 0.7rem; padding: 0.2rem; line-height: 1; transition: color 0.15s; }
  .fifty-cart-item-remove:hover { color: rgba(200,64,26,0.85); }

  /* CART BUNDLE (subscription + setup fee locked together) */
  .fifty-cart-bundle { margin: 0.8rem 1.6rem 0; border: 1px solid rgba(200,64,26,0.28); border-radius: 3px; background: rgba(200,64,26,0.06); overflow: hidden; }
  .fifty-cart-bundle-top { padding: 0.85rem 1rem 0.6rem; display: flex; align-items: center; gap: 0.6rem; border-bottom: 1px solid rgba(200,64,26,0.14); }
  .fifty-cart-bundle-badge { font-family: 'DM Mono', monospace; font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; background: var(--accent); color: white; padding: 0.18rem 0.5rem; border-radius: 2px; flex-shrink: 0; }
  .fifty-cart-bundle-name { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700; color: white; letter-spacing: -0.01em; }
  .fifty-cart-bundle-lines { padding: 0.55rem 1rem 0; }
  .fifty-cart-bundle-line { display: flex; justify-content: space-between; align-items: center; padding: 0.3rem 0; }
  .fifty-cart-bundle-line-name { font-size: 0.7rem; color: rgba(255,255,255,0.4); }
  .fifty-cart-bundle-line-price { font-size: 0.7rem; color: rgba(255,255,255,0.5); }
  .fifty-cart-bundle-foot { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 1rem 0.75rem; margin-top: 0.4rem; border-top: 1px solid rgba(200,64,26,0.14); }
  .fifty-cart-bundle-total-label { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.28); }
  .fifty-cart-bundle-total-right { display: flex; align-items: center; gap: 0.55rem; }
  .fifty-cart-bundle-total { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: white; }

  /* CART EMPTY + LOADING */
  .fifty-cart-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3.5rem 2rem; text-align: center; min-height: 320px; }
  .fifty-cart-empty-bag { width: 52px; height: 52px; margin: 0 auto 1.4rem; opacity: 0.18; }
  .fifty-cart-empty-bag svg { width: 100%; height: 100%; stroke: white; fill: none; stroke-width: 1.2; stroke-linecap: round; stroke-linejoin: round; }
  .fifty-cart-empty-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: rgba(255,255,255,0.6); margin-bottom: 0.5rem; }
  .fifty-cart-empty-sub { font-size: 0.74rem; color: rgba(255,255,255,0.25); line-height: 1.75; margin-bottom: 2rem; max-width: 220px; }
  .fifty-cart-empty-cta { background: var(--accent); color: white; border: none; padding: 0.8rem 1.8rem; font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; border-radius: 2px; cursor: pointer; text-decoration: none; transition: background 0.2s, transform 0.15s; display: inline-block; }
  .fifty-cart-empty-cta:hover { background: #e04d20; transform: translateY(-1px); }
  .fifty-cart-loading { display: flex; align-items: center; justify-content: center; min-height: 200px; }
  .fifty-cart-spinner { width: 22px; height: 22px; border: 2px solid rgba(255,255,255,0.08); border-top-color: var(--accent); border-radius: 50%; animation: fifty-spin 0.65s linear infinite; }
  @keyframes fifty-spin { to { transform: rotate(360deg); } }

  /* CART FOOTER */
  .fifty-cart-foot { border-top: 1px solid rgba(255,255,255,0.07); padding: 1.2rem 1.6rem 1.5rem; flex-shrink: 0; background: rgba(0,0,0,0.18); }
  .fifty-cart-subtotal-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.35rem; }
  .fifty-cart-subtotal-label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35); }
  .fifty-cart-subtotal-amount { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 900; color: white; line-height: 1; }
  .fifty-cart-foot-note { font-size: 0.63rem; color: rgba(255,255,255,0.2); line-height: 1.55; margin-bottom: 1.1rem; }
  .fifty-cart-checkout { width: 100%; background: white; color: var(--ink); border: none; padding: 1rem; font-family: 'DM Mono', monospace; font-size: 0.76rem; letter-spacing: 0.12em; text-transform: uppercase; border-radius: 2px; cursor: pointer; transition: background 0.2s; display: block; text-align: center; text-decoration: none; font-weight: 500; margin-bottom: 0.65rem; }
  .fifty-cart-checkout:hover { background: #f5f0e8; }
  .fifty-cart-continue { width: 100%; background: none; border: 1px solid rgba(255,255,255,0.09); color: rgba(255,255,255,0.35); padding: 0.7rem; font-family: 'DM Mono', monospace; font-size: 0.67rem; letter-spacing: 0.1em; text-transform: uppercase; border-radius: 2px; cursor: pointer; transition: border-color 0.2s, color 0.2s; }
  .fifty-cart-continue:hover { border-color: rgba(255,255,255,0.22); color: rgba(255,255,255,0.65); }

  /* Mobile drawer full-width */
  @media (max-width: 480px) {
    .fifty-cart-drawer { width: 100vw; }
    .fifty-account-drop { right: -0.5rem; }
  }

  /* NAV MOBILE MENU */
  .fifty-nav-hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; background: none; border: none; cursor: pointer; padding: 0.3rem; z-index: 210; }
  .fifty-nav-hamburger span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform 0.25s, opacity 0.25s; }
  .fifty-nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .fifty-nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .fifty-nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .fifty-nav-mobile { display: none; position: fixed; top: 61px; left: 0; right: 0; background: var(--paper); border-bottom: 1px solid var(--border); z-index: 199; padding: 1rem 0; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .fifty-nav-mobile.open { display: block; }
  .fifty-nav-mobile ul { list-style: none; display: flex; flex-direction: column; }
  .fifty-nav-mobile li { border-bottom: 1px solid var(--border); }
  .fifty-nav-mobile li:last-child { border-bottom: none; }
  .fifty-nav-mobile button, .fifty-nav-mobile a { display: block; width: 100%; text-align: left; padding: 1rem 2rem; background: none; border: none; cursor: pointer; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .fifty-nav-mobile button:hover, .fifty-nav-mobile a:hover { color: var(--ink); }
  .fifty-nav-mobile .fifty-nav-mobile-cta { background: var(--ink); color: var(--paper) !important; text-align: center; margin: 1rem 1.5rem 0.5rem; border-radius: 2px; }

  /* RESPONSIVE */
  @media (max-width: 900px) { .fifty-portfolio-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .fifty-features-inner { grid-template-columns: 1fr; }
    .fifty-features-left { position: static; }
    .fifty-process-grid { grid-template-columns: 1fr 1fr; }
    .fifty-plan-items { grid-template-columns: 1fr; }
    .fifty-portfolio-grid { grid-template-columns: 1fr; }
    .fifty-scene-4 .fifty-split { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    /* Nav */
    .fifty-nav-links { display: none; }
    .fifty-nav-hamburger { display: flex; }
    .fifty-nav { padding: 1rem 1.5rem; }
    /* Hero */
    .fifty-hero { padding: 6rem 1.5rem 3rem; }
    .fifty-hero-bg-text { display: none; }
    .fifty-hero-ctas { flex-direction: column; align-items: center; }
    .fifty-hero-ctas .fifty-btn-primary, .fifty-hero-ctas .fifty-btn-ghost { width: 100%; max-width: 320px; text-align: center; justify-content: center; display: block; }
    /* Cinema */
    .fifty-brand-stats { gap: 1.6rem; }
    .fifty-brand-divider { display: none; }
    .fifty-play-btn { padding: 0.75rem 1.5rem 0.75rem 0.75rem; font-size: 0.72rem; }
    .fifty-play-icon { width: 42px; height: 42px; }
    /* Marquee */
    .fifty-marquee-bar { font-size: 0.72rem; }
    /* Why Us */
    .fifty-why { padding: 4rem 1.5rem; }
    .fifty-why-table-wrap { margin: 0 -1.5rem; padding: 0 1.5rem; width: calc(100% + 3rem); }
    /* Sections */
    .fifty-section { padding: 4rem 1.5rem; }
    /* FAQ */
    .fifty-faq-q { font-size: 0.9rem; }
    /* CTA band */
    .fifty-cta-band { padding: 4rem 1.5rem; }
  }
  @media (max-width: 480px) { .fifty-process-grid { grid-template-columns: 1fr; } }
