{% comment %}
  PlanSelector.liquid — Fifty pre-checkout plan selection page
  Shows plan card, logo add-on toggle, live order summary, reassurance copy
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

{% style %}
  #header-group, footer { display: none !important; }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #111111; }

  /* ── PAGE SHELL ── */
  .fp { font-family: 'DM Mono', monospace; background: #111111; min-height: 100vh; color: #f5f0e8; padding-bottom: 5rem; }

  /* ── NAV ── */
  .fp-nav { display: flex; align-items: center; justify-content: space-between; padding: 1.6rem 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .fp-logo { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 900; letter-spacing: -0.03em; color: #f5f0e8; text-decoration: none; }
  .fp-logo span { color: #c8401a; }
  .fp-nav-back { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.2s; }
  .fp-nav-back:hover { color: rgba(255,255,255,0.6); }

  /* ── HERO ── */
  .fp-hero { text-align: center; padding: 3.5rem 2rem 2.5rem; max-width: 560px; margin: 0 auto; }
  .fp-hero-label { font-size: 0.65rem; letter-spacing: 0.28em; text-transform: uppercase; color: #c8401a; margin-bottom: 1rem; }
  .fp-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.03em; color: white; margin-bottom: 0.9rem; }
  .fp-hero h1 em { font-style: italic; color: #c8401a; }
  .fp-hero p { font-size: 0.82rem; color: rgba(255,255,255,0.4); line-height: 1.85; }

  /* ── MAIN WRAP ── */
  .fp-wrap { max-width: 500px; margin: 0 auto; padding: 0 1.5rem; }

  /* ── PLAN CARD ── */
  .fp-plan { border: 1px solid rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; margin-bottom: 1rem; }
  .fp-plan-header { background: #c8401a; padding: 1.4rem 2rem; display: flex; justify-content: space-between; align-items: center; }
  .fp-plan-name { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 900; color: white; letter-spacing: -0.02em; }
  .fp-plan-badge { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.75); background: rgba(0,0,0,0.18); padding: 0.28rem 0.7rem; border-radius: 2px; }
  .fp-plan-price { padding: 1.6rem 2rem; display: flex; align-items: baseline; gap: 0.4rem; background: rgba(200,64,26,0.08); border-bottom: 1px solid rgba(255,255,255,0.07); }
  .fp-plan-currency { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: rgba(255,255,255,0.55); align-self: flex-start; margin-top: 0.5rem; }
  .fp-plan-amount { font-family: 'Playfair Display', serif; font-size: 3.5rem; font-weight: 900; color: white; line-height: 1; }
  .fp-plan-period { font-size: 0.72rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.1em; }
  .fp-plan-setup-note { padding: 0.9rem 2rem; font-size: 0.73rem; color: rgba(255,255,255,0.45); background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.06); line-height: 1.5; }
  .fp-plan-setup-note strong { color: rgba(255,255,255,0.75); font-weight: 500; }
  .fp-plan-features { padding: 1.5rem 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; }
  .fp-feature { display: flex; align-items: flex-start; gap: 0.55rem; font-size: 0.73rem; color: rgba(255,255,255,0.55); line-height: 1.4; }
  .fp-feature-tick { color: #c8401a; flex-shrink: 0; font-size: 0.7rem; margin-top: 0.1rem; }

  /* ── LOGO ADD-ON ── */
  .fp-addon-label { font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.25); margin-bottom: 0.5rem; padding: 0 0.1rem; }
  .fp-addon { border: 1px solid rgba(255,255,255,0.09); border-radius: 3px; padding: 1.3rem 1.6rem; display: flex; align-items: center; gap: 1.1rem; cursor: pointer; transition: border-color 0.2s, background 0.2s; margin-bottom: 1.2rem; background: rgba(255,255,255,0.02); user-select: none; }
  .fp-addon:hover { border-color: rgba(255,255,255,0.22); background: rgba(255,255,255,0.04); }
  .fp-addon.selected { border-color: #c8401a; background: rgba(200,64,26,0.07); }
  .fp-check { width: 20px; height: 20px; border: 1.5px solid rgba(255,255,255,0.2); border-radius: 3px; flex-shrink: 0; display: grid; place-items: center; transition: border-color 0.2s, background 0.2s; }
  .fp-addon.selected .fp-check { background: #c8401a; border-color: #c8401a; }
  .fp-check-icon { display: none; color: white; font-size: 0.7rem; line-height: 1; }
  .fp-addon.selected .fp-check-icon { display: block; }
  .fp-addon-body { flex: 1; min-width: 0; }
  .fp-addon-title { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 0.2rem; }
  .fp-addon-desc { font-size: 0.7rem; color: rgba(255,255,255,0.35); line-height: 1.5; }
  .fp-addon-price { text-align: right; flex-shrink: 0; }
  .fp-addon-price-amount { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; color: white; display: block; }
  .fp-addon-price-label { font-size: 0.6rem; color: rgba(255,255,255,0.3); letter-spacing: 0.1em; text-transform: uppercase; }

  /* ── REASSURANCE ── */
  .fp-reassure { border: 1px solid rgba(255,255,255,0.07); border-radius: 3px; padding: 1.2rem 1.6rem; display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 1.4rem; background: rgba(255,255,255,0.015); }
  .fp-reassure-icon { font-size: 1.1rem; flex-shrink: 0; line-height: 1.4; }
  .fp-reassure-text { font-size: 0.76rem; color: rgba(255,255,255,0.45); line-height: 1.75; }
  .fp-reassure-text strong { color: rgba(255,255,255,0.82); font-weight: 500; }

  /* ── ORDER SUMMARY ── */
  .fp-summary { margin-bottom: 1.4rem; }
  .fp-summary-row { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.73rem; color: rgba(255,255,255,0.38); }
  .fp-summary-row:last-child { border-bottom: none; }
  .fp-summary-row.fp-total { font-size: 0.8rem; color: rgba(255,255,255,0.7); padding-top: 0.7rem; }
  .fp-summary-row.fp-total span:last-child { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: white; }

  /* ── CTA ── */
  .fp-cta { width: 100%; background: white; color: #111; border: none; padding: 1.1rem 2rem; font-family: 'DM Mono', monospace; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; border-radius: 3px; display: flex; align-items: center; justify-content: center; gap: 0.75rem; text-decoration: none; font-weight: 500; }
  .fp-cta:hover { background: #f0ebe3; transform: translateY(-1px); }

  /* ── PAYMENT NOTE ── */
  .fp-pay-note { text-align: center; font-size: 0.65rem; color: rgba(255,255,255,0.2); margin-top: 1rem; letter-spacing: 0.06em; line-height: 1.7; }
  .fp-pay-icons { display: flex; justify-content: center; align-items: center; gap: 0.6rem; margin-top: 0.6rem; flex-wrap: wrap; }
  .fp-pay-icon { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 3px; padding: 0.25rem 0.6rem; font-size: 0.65rem; color: rgba(255,255,255,0.35); letter-spacing: 0.06em; }

  /* ── TRUST STRIP ── */
  .fp-trust { display: flex; justify-content: center; gap: 2rem; margin-top: 1.8rem; flex-wrap: wrap; padding-bottom: 1rem; }
  .fp-trust-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.63rem; color: rgba(255,255,255,0.18); letter-spacing: 0.1em; text-transform: uppercase; }

  /* ── DIVIDER ── */
  .fp-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 1.2rem 0; }

  /* ── T&C CHECKBOX ── */
  .fp-tc-row { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1rem; padding: 1rem 1.2rem; border: 1px solid rgba(255,255,255,0.07); border-radius: 3px; background: rgba(255,255,255,0.02); cursor: pointer; transition: border-color 0.2s, background 0.2s; }
  .fp-tc-row:hover { border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.035); }
  .fp-tc-checkbox { width: 20px; height: 20px; border: 1.5px solid rgba(255,255,255,0.25); border-radius: 3px; flex-shrink: 0; display: grid; place-items: center; transition: border-color 0.2s, background 0.2s; margin-top: 0.05rem; }
  .fp-tc-checkbox.checked { background: #c8401a; border-color: #c8401a; }
  .fp-tc-checkbox .fp-tc-tick { display: none; color: white; font-size: 0.7rem; }
  .fp-tc-checkbox.checked .fp-tc-tick { display: block; }
  .fp-tc-text { font-size: 0.72rem; color: rgba(255,255,255,0.55); line-height: 1.65; }
  .fp-tc-text a { color: #c8401a; text-decoration: underline; cursor: pointer; }
  .fp-tc-text a:hover { color: #e04d20; }

  /* ── CTA DISABLED STATE ── */
  .fp-cta { transition: background 0.2s, transform 0.15s, opacity 0.3s; }
  .fp-cta.fp-cta-disabled { opacity: 0.25; pointer-events: none; }

  /* ── T&C MODAL ── */
  .fp-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.82); z-index: 9000; align-items: center; justify-content: center; padding: 1.5rem; }
  .fp-modal-overlay.open { display: flex; }
  .fp-modal { background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; max-width: 640px; width: 100%; max-height: 85vh; display: flex; flex-direction: column; }
  .fp-modal-head { padding: 1.4rem 1.8rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.07); display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-shrink: 0; }
  .fp-modal-title { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 900; color: white; letter-spacing: -0.02em; }
  .fp-modal-close { background: none; border: none; color: rgba(255,255,255,0.3); font-size: 1.3rem; cursor: pointer; padding: 0; line-height: 1; flex-shrink: 0; transition: color 0.2s; }
  .fp-modal-close:hover { color: rgba(255,255,255,0.7); }
  .fp-modal-body { padding: 1.4rem 1.8rem 1.8rem; overflow-y: auto; font-size: 0.73rem; color: rgba(255,255,255,0.45); line-height: 1.9; }
  .fp-modal-body h3 { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin: 1.4rem 0 0.4rem; }
  .fp-modal-body h3:first-child { margin-top: 0; }
  .fp-modal-body p { margin-bottom: 0.6rem; }
  .fp-modal-body strong { color: rgba(255,255,255,0.75); font-weight: 500; }
  .fp-modal-foot { padding: 1rem 1.8rem; border-top: 1px solid rgba(255,255,255,0.07); display: flex; justify-content: flex-end; flex-shrink: 0; }
  .fp-modal-accept { background: #c8401a; color: white; border: none; padding: 0.7rem 1.6rem; font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; border-radius: 3px; transition: background 0.2s; }
  .fp-modal-accept:hover { background: #a8341a; }

  /* ── MOBILE ── */
  @media (max-width: 520px) {
    .fp-plan-features { grid-template-columns: 1fr; }
    .fp-nav { padding: 1.2rem 1.5rem; }
    .fp-hero { padding: 2.5rem 1.5rem 2rem; }
    .fp-plan-price { padding: 1.2rem 1.5rem; }
    .fp-plan-header { padding: 1.2rem 1.5rem; }
    .fp-plan-setup-note { padding: 0.8rem 1.5rem; }
    .fp-plan-features { padding: 1.2rem 1.5rem; }
    .fp-addon { flex-wrap: wrap; }
    .fp-addon-price { margin-left: auto; }
  }
{% endstyle %}

