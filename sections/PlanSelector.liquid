    </div>
    <div class="fp-modal-foot">
      <button class="fp-modal-accept" onclick="fpAcceptTc()">I Accept &nbsp;→</button>
    </div>
  </div>
</div>

<script>
  var FP_SUBSCRIPTION = 53809850089811;
  var FP_SETUP       = 53809949933907;
  var FP_LOGO        = 53809996759379;

  var fpLogoSelected = false;
  var fpTcAccepted = false;

  /* ── T&C MODAL ── */
  function fpOpenTc() {
    document.getElementById('fpTcModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function fpCloseTc() {
    document.getElementById('fpTcModal').classList.remove('open');
    document.body.style.overflow = '';
  }
  function fpCloseTcIfOutside(e) {
    if (e.target === document.getElementById('fpTcModal')) fpCloseTc();
  }
  function fpAcceptTc() {
    fpCloseTc();
    if (!fpTcAccepted) {
      fpTcAccepted = true;
      document.getElementById('fpTcBox').classList.add('checked');
      document.getElementById('fpTcRow').setAttribute('aria-checked', 'true');
      var cta = document.getElementById('fpCta');
      cta.classList.remove('fp-cta-disabled');
      cta.removeAttribute('title');
    }
  }

  /* ── T&C CHECKBOX ── */
  function fpToggleTc() {
    fpTcAccepted = !fpTcAccepted;
    var box = document.getElementById('fpTcBox');
    var row = document.getElementById('fpTcRow');
    box.classList.toggle('checked', fpTcAccepted);
    row.setAttribute('aria-checked', fpTcAccepted.toString());
    var cta = document.getElementById('fpCta');
    if (fpTcAccepted) {
      cta.classList.remove('fp-cta-disabled');
      cta.removeAttribute('title');
    } else {
      cta.classList.add('fp-cta-disabled');
      cta.setAttribute('title', 'Please accept the Terms & Conditions above to continue');
    }
  }

  /* ── ESCAPE KEY TO CLOSE MODAL ── */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') fpCloseTc();
  });

  function fpToggleAddon() {
    fpLogoSelected = !fpLogoSelected;
    var el = document.getElementById('fpAddon');
    el.classList.toggle('selected', fpLogoSelected);
    el.setAttribute('aria-checked', fpLogoSelected.toString());
    fpUpdateSummary();
  }

  function fpUpdateSummary() {
    var todayTotal = 100; // setup + first month
    var rows = '';

    rows += '<div class="fp-summary-row"><span>Website subscription</span><span>£50.00 / mo</span></div>';
    rows += '<div class="fp-summary-row"><span>Setup fee (one-time)</span><span>£50.00</span></div>';

    if (fpLogoSelected) {
      todayTotal += 19.99;
      rows += '<div class="fp-summary-row"><span>Professional logo design</span><span>£19.99</span></div>';
    }

    rows += '<div class="fp-summary-row fp-total"><span>Due today</span><span id="fpTotal">£' + todayTotal.toFixed(2) + '</span></div>';
    document.getElementById('fpSummary').innerHTML = rows;

    var cartUrl = '/cart/' + FP_SUBSCRIPTION + ':1,' + FP_SETUP + ':1';
    if (fpLogoSelected) cartUrl += ',' + FP_LOGO + ':1';
    var cta = document.getElementById('fpCta');
    cta.href = cartUrl;
    // preserve disabled state
    if (!fpTcAccepted) {
      cta.classList.add('fp-cta-disabled');
    }
  }
</script>

